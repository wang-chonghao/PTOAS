// End-to-end verification that reduce ops (trowsum) with computed dynamic
// shapes can be fused with their producer elementwise ops.  The reduce's
// input domain (32x32) and output domain (32x1) must be handled correctly:
// the solver should merge the input rows with the output rows (both iterate
// over the same row range) and bind output.cols=1, while still keeping the
// tadd/tmul/trowsum chain in one fusion group.
//
// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level3 --enable-op-fusion --enable-shape-inference --emit-vpto %s --mlir-print-ir-after=pto-fusion-plan -o /dev/null 2>&1 | FileCheck --check-prefix=PLAN %s
// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level3 --enable-op-fusion --enable-shape-inference --emit-vpto %s --mlir-print-ir-after=pto-low-level-loop-fusion -o /dev/null 2>&1 | FileCheck --check-prefix=LOOP %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  // tadd -> tmul -> trowsum chain where each stage uses separately computed
  // mins(vrow,c32)/mins(vcol,c32) as valid_row/valid_col.  The reduce
  // (trowsum) iterates over the input domain rows and outputs valid=?x1.
  func.func @reduce_computed_shape_e2e(
      %dst_ptr: !pto.ptr<f32>,
      %vrow: index,
      %vcol: index) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c32 = arith.constant 32 : index
    %c8 = arith.constant 8 : index
    %c1024 = arith.constant 1024 : index
    %row0 = arith.minsi %vrow, %c32 : index
    %col0 = arith.minsi %vcol, %c32 : index
    %row1 = arith.minsi %vrow, %c32 : index
    %col1 = arith.minsi %vcol, %c32 : index

    %dst_view = pto.make_tensor_view %dst_ptr,
      shape = [%c1, %c1, %c1, %c32, %c32],
      strides = [%c1024, %c1024, %c1024, %c32, %c1]
      : !pto.tensor_view<1x1x1x32x32xf32>
    %dst_part = pto.partition_view %dst_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c32, %c32]
      : !pto.tensor_view<1x1x1x32x32xf32> -> !pto.partition_tensor_view<1x1x1x32x32xf32>

    %c0_i64 = arith.constant 0 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c12288_i64 = arith.constant 12288 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c20480_i64 = arith.constant 20480 : i64
    %c24576_i64 = arith.constant 24576 : i64

    // Elementwise inputs: same computed shape %row0/%col0.
    %lhs = pto.alloc_tile addr = %c0_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %rhs = pto.alloc_tile addr = %c4096_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %scale = pto.alloc_tile addr = %c8192_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %add = pto.alloc_tile addr = %c12288_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %mul = pto.alloc_tile addr = %c16384_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    // Reduce: input domain is 32x32, output domain is 32x1 (cols reduced).
    %reduce_tmp = pto.alloc_tile addr = %c20480_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %reduce = pto.alloc_tile addr = %c24576_i64 valid_row = %row1 : !pto.tile_buf<vec, 32x8xf32, valid=?x1>

    pto.tadd ins(%lhs, %rhs : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%add : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.tmul ins(%add, %scale : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%mul : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.trowsum ins(%mul, %reduce_tmp : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%reduce : !pto.tile_buf<vec, 32x8xf32, valid=?x1>)
    return
  }
}

// All three ops share group_id=0 (same iteration domain rows).
// PLAN-LABEL: func.func @reduce_computed_shape_e2e(
// PLAN: pto.tadd {{.*}} {pto.fusion.group_id = 0 : i64, pto.fusion.order = 0 : i64}
// PLAN: pto.tmul {{.*}} {pto.fusion.group_id = 0 : i64, pto.fusion.order = 1 : i64}
// PLAN: pto.trowsum {{.*}} {pto.fusion.group_id = 0 : i64, pto.fusion.order = 2 : i64}

// elementwise + reduce fused into one row loop with epilogue store
// LOOP-LABEL: func.func @reduce_computed_shape_e2e(
// LOOP: %[[ROW_BOUND:.*]] = arith.minsi %{{.*}}, %{{.*}} : index
// LOOP: %[[COL_BOUND:.*]] = arith.minsi %{{.*}}, %{{.*}} : index
// LOOP: pto.fusion_region {
// LOOP: scf.for {{.*}} to %[[ROW_BOUND]] step {{.*}} iter_args
// LOOP: %{{.*}}:4 = scf.for {{.*}} to %[[COL_BOUND]] step {{.*}} iter_args({{.*}}, {{.*}}, {{.*}}, {{.*}}) -> (i32, i32, i32, !pto.vreg<64xf32>) {
// LOOP: pto.vadd
// LOOP: pto.vmul
// Reduce computation inside the same col loop.
// LOOP: pto.vcadd
// LOOP: %{{.*}} = pto.vadd
// LOOP: scf.yield {{.*}} : i32, i32, i32, !pto.vreg<64xf32>
// LOOP: }
// Epilogue: row-reduction result store after inner loop.
// LOOP: pto.vsts
// LOOP: scf.yield {{.*}} : i32
// LOOP: }
// LOOP: pto.yield
