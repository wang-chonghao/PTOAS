// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level2 --enable-op-fusion --use-vfsim-fusion-planner --dump-vfsim-unroll-test --emit-vpto %s --mlir-print-ir-after=pto-fusion-plan -o /dev/null 2>&1 | FileCheck %s --check-prefix=PLAN
// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level2 --enable-op-fusion --use-vfsim-fusion-planner --emit-vpto %s --mlir-print-ir-after=pto-low-level-loop-fusion -o /dev/null 2>&1 | FileCheck %s --check-prefix=LLF

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @fusion_loop_unroll_gelu_poly_vfsim(
      %x_ptr: !pto.ptr<f32>, %out_ptr: !pto.ptr<f32>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c24 = arith.constant 24 : index
    %c32 = arith.constant 32 : index
    %c768 = arith.constant 768 : index
    %c_neg4 = arith.constant -4.000000e+00 : f32
    %c_pos4 = arith.constant 4.000000e+00 : f32
    %c05 = arith.constant 5.000000e-01 : f32
    %c03989 = arith.constant 3.989000e-01 : f32
    %c00447 = arith.constant 4.470000e-02 : f32

    %x_view = pto.make_tensor_view %x_ptr,
      shape = [%c1, %c1, %c1, %c24, %c32],
      strides = [%c768, %c768, %c768, %c32, %c1]
      : !pto.tensor_view<1x1x1x24x32xf32>
    %out_view = pto.make_tensor_view %out_ptr,
      shape = [%c1, %c1, %c1, %c24, %c32],
      strides = [%c768, %c768, %c768, %c32, %c1]
      : !pto.tensor_view<1x1x1x24x32xf32>

    %x_part = pto.partition_view %x_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c24, %c32]
      : !pto.tensor_view<1x1x1x24x32xf32> -> !pto.partition_tensor_view<1x1x1x24x32xf32>
    %out_part = pto.partition_view %out_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c24, %c32]
      : !pto.tensor_view<1x1x1x24x32xf32> -> !pto.partition_tensor_view<1x1x1x24x32xf32>

    %x = pto.alloc_tile : !pto.tile_buf<vec, 24x32xf32>
    %x_clamp = pto.alloc_tile : !pto.tile_buf<vec, 24x32xf32>
    %x2 = pto.alloc_tile : !pto.tile_buf<vec, 24x32xf32>
    %x3 = pto.alloc_tile : !pto.tile_buf<vec, 24x32xf32>
    %poly = pto.alloc_tile : !pto.tile_buf<vec, 24x32xf32>
    %gate = pto.alloc_tile : !pto.tile_buf<vec, 24x32xf32>
    %out = pto.alloc_tile : !pto.tile_buf<vec, 24x32xf32>

    pto.tload ins(%x_part : !pto.partition_tensor_view<1x1x1x24x32xf32>)
              outs(%x : !pto.tile_buf<vec, 24x32xf32>)

    // GeLU-like polynomial: x * (0.5 + 0.3989*x + 0.0447*x^3).
    pto.tmaxs ins(%x, %c_neg4 : !pto.tile_buf<vec, 24x32xf32>, f32)
              outs(%x_clamp : !pto.tile_buf<vec, 24x32xf32>)
    pto.tmins ins(%x_clamp, %c_pos4 : !pto.tile_buf<vec, 24x32xf32>, f32)
              outs(%x_clamp : !pto.tile_buf<vec, 24x32xf32>)
    pto.tmul ins(%x_clamp, %x_clamp : !pto.tile_buf<vec, 24x32xf32>, !pto.tile_buf<vec, 24x32xf32>)
             outs(%x2 : !pto.tile_buf<vec, 24x32xf32>)
    pto.tmul ins(%x2, %x_clamp : !pto.tile_buf<vec, 24x32xf32>, !pto.tile_buf<vec, 24x32xf32>)
             outs(%x3 : !pto.tile_buf<vec, 24x32xf32>)
    pto.tmuls ins(%x3, %c00447 : !pto.tile_buf<vec, 24x32xf32>, f32)
              outs(%poly : !pto.tile_buf<vec, 24x32xf32>)
    pto.tadds ins(%poly, %c03989 : !pto.tile_buf<vec, 24x32xf32>, f32)
              outs(%poly : !pto.tile_buf<vec, 24x32xf32>)
    pto.tmul ins(%poly, %x_clamp : !pto.tile_buf<vec, 24x32xf32>, !pto.tile_buf<vec, 24x32xf32>)
             outs(%gate : !pto.tile_buf<vec, 24x32xf32>)
    pto.tadds ins(%gate, %c05 : !pto.tile_buf<vec, 24x32xf32>, f32)
              outs(%gate : !pto.tile_buf<vec, 24x32xf32>)
    pto.tmul ins(%x_clamp, %gate : !pto.tile_buf<vec, 24x32xf32>, !pto.tile_buf<vec, 24x32xf32>)
             outs(%out : !pto.tile_buf<vec, 24x32xf32>)

    pto.tstore ins(%out : !pto.tile_buf<vec, 24x32xf32>)
               outs(%out_part : !pto.partition_tensor_view<1x1x1x24x32xf32>)
    return
  }
}

// PLAN: vfsim unroll test: group_size=
// PLAN: unroll=1 valid=true supported=true cycles=
// PLAN: unroll=4 valid=true supported=true cycles=
// PLAN: unroll=6 valid=true supported=true cycles=
// PLAN: selected_unroll=6
// PLAN: pto.fusion.unroll = 6 : i64

// LLF: // -----// IR Dump After PTOLowLevelLoopFusion (pto-low-level-loop-fusion) //----- //
// LLF-LABEL: func.func @fusion_loop_unroll_gelu_poly_vfsim(
// LLF: pto.fusion_region
// LLF: pto.fusion.loop_unroll = 6 : i64
