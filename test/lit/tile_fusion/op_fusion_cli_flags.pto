// Guards --enable-op-fusion CLI visibility and warning behavior on the
// EmitC mainline frontend-fusion gate.
//
// RUN: ptoas --help-hidden 2>&1 | FileCheck %s --check-prefix=HELP
// RUN: ptoas --pto-arch=a5 --pto-level=level2 --enable-op-fusion %s -o /dev/null 2>&1 | FileCheck %s --allow-empty --check-prefix=LEVEL2
// RUN: ptoas --pto-arch=a5 --pto-level=level1 --enable-op-fusion %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=LEVEL1
// RUN: ptoas --pto-arch=a3 --enable-op-fusion %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=A3

module {
  func.func @fusion_cli_flags() {
    return
  }
}

// HELP: --enable-op-fusion

// LEVEL2-NOT: Warning: --enable-op-fusion is ignored

// LEVEL1: Warning: --enable-op-fusion is ignored because --pto-level=level2 or level3 is required.

// A3: Warning: --enable-op-fusion is ignored because --pto-arch=a5 is required.
