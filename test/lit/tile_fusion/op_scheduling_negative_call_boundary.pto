// Guards OpScheduling against moving planned fusion members across an unrelated
// function call boundary. When a HardBoundary prevents contiguous fusion group
// formation, the group is silently skipped without last-use annotation and
// compilation proceeds normally.
//
// RUN: ptoas --pto-arch=a5 --pto-level=level2 --enable-op-fusion --emit-pto-ir %s --mlir-print-ir-after=pto-mark-last-use -o /dev/null 2>&1 | FileCheck %s

module {
  func.func private @touch_boundary()

  func.func @op_scheduling_negative_call_boundary(
      %full0: !pto.tile_buf<vec, 32x32xf32>,
      %full1: !pto.tile_buf<vec, 32x32xf32>,
      %full2: !pto.tile_buf<vec, 32x32xf32>) {
    %tmp0 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp1 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>

    pto.tadd ins(%full0, %full1 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32>)
    func.call @touch_boundary() : () -> ()
    pto.tadd ins(%tmp0, %full2 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp1 : !pto.tile_buf<vec, 32x32xf32>)
    return
  }
}

// CHECK: // -----// IR Dump After PTOMarkLastUse (pto-mark-last-use) //----- //
// CHECK-LABEL: func.func @op_scheduling_negative_call_boundary(
// CHECK: pto.tadd
// CHECK-NOT: pto.fusion.group_id
// CHECK-NOT: pto.last_use
// CHECK: call @touch_boundary()
// CHECK-NOT: pto.fusion.group_id
// CHECK-NOT: pto.last_use
// CHECK: pto.tadd
// CHECK-NOT: pto.fusion.group_id
// CHECK-NOT: pto.last_use
// CHECK: return
// CHECK-NOT: error:
