// Guards PTOLowLevelLoopFusion on dynamically shaped fusion stages. Adjacent
// stages use separately materialized but structurally equivalent dynamic
// valid_row/valid_col expressions, so the low-level pass must prove the loop
// headers equivalent instead of relying on every tile sharing the same SSA value.
//
// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level3 --enable-op-fusion --enable-shape-inference --emit-vpto %s --mlir-print-ir-after=pto-low-level-loop-fusion -o /dev/null 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @fusion_low_level_loop_dynamic_shape(
      %dst_ptr: !pto.ptr<f32>,
      %vrow: index,
      %vcol: index) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c32 = arith.constant 32 : index
    %c1024 = arith.constant 1024 : index
    %row0 = arith.minsi %vrow, %c32 : index
    %col0 = arith.minsi %vcol, %c32 : index
    %row1 = arith.minsi %vrow, %c32 : index
    %col1 = arith.minsi %vcol, %c32 : index
    %row2 = arith.minsi %vrow, %c32 : index
    %col2 = arith.minsi %vcol, %c32 : index

    %dst_view = pto.make_tensor_view %dst_ptr,
      shape = [%c1, %c1, %c1, %c32, %c32],
      strides = [%c1024, %c1024, %c1024, %c32, %c1]
      : !pto.tensor_view<1x1x1x32x32xf32>
    %dst_part = pto.partition_view %dst_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c32, %c32]
      : !pto.tensor_view<1x1x1x32x32xf32> -> !pto.partition_tensor_view<1x1x1x32x32xf32>

    %c0_i64 = arith.constant 0 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c12288_i64 = arith.constant 12288 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c20480_i64 = arith.constant 20480 : i64
    %c24576_i64 = arith.constant 24576 : i64

    %a = pto.alloc_tile addr = %c0_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %b = pto.alloc_tile addr = %c4096_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %c = pto.alloc_tile addr = %c8192_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %d = pto.alloc_tile addr = %c12288_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %tmp0 = pto.alloc_tile addr = %c16384_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %tmp1 = pto.alloc_tile addr = %c20480_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %out = pto.alloc_tile addr = %c24576_i64 valid_row = %row2 valid_col = %col2 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>

    pto.tadd ins(%a, %b : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.tadd ins(%c, %d : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%tmp1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.tadd ins(%tmp0, %tmp1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%out : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.tstore ins(%out : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x32x32xf32>)
    return
  }

  func.func @fusion_low_level_loop_computed_dynamic_shape(
      %dst_ptr: !pto.ptr<f32>,
      %vrow: index,
      %vcol: index) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c32 = arith.constant 32 : index
    %c1024 = arith.constant 1024 : index
    %row_in_range0 = arith.cmpi ule, %vrow, %c32 : index
    %col_in_range0 = arith.cmpi ule, %vcol, %c32 : index
    %tile_row0 = arith.select %row_in_range0, %vrow, %c32 : index
    %tile_col0 = arith.select %col_in_range0, %vcol, %c32 : index
    %row_in_range1 = arith.cmpi ule, %vrow, %c32 : index
    %col_in_range1 = arith.cmpi ule, %vcol, %c32 : index
    %tile_row1 = arith.select %row_in_range1, %vrow, %c32 : index
    %tile_col1 = arith.select %col_in_range1, %vcol, %c32 : index

    %dst_view = pto.make_tensor_view %dst_ptr,
      shape = [%c1, %c1, %c1, %c32, %c32],
      strides = [%c1024, %c1024, %c1024, %c32, %c1]
      : !pto.tensor_view<1x1x1x32x32xf32>
    %dst_part = pto.partition_view %dst_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c32, %c32]
      : !pto.tensor_view<1x1x1x32x32xf32> -> !pto.partition_tensor_view<1x1x1x32x32xf32>

    %c0_i64 = arith.constant 0 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c12288_i64 = arith.constant 12288 : i64
    %c16384_i64 = arith.constant 16384 : i64

    %a = pto.alloc_tile addr = %c0_i64 valid_row = %tile_row0 valid_col = %tile_col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %b = pto.alloc_tile addr = %c4096_i64 valid_row = %tile_row0 valid_col = %tile_col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %c = pto.alloc_tile addr = %c8192_i64 valid_row = %tile_row1 valid_col = %tile_col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %tmp0 = pto.alloc_tile addr = %c12288_i64 valid_row = %tile_row0 valid_col = %tile_col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %out = pto.alloc_tile addr = %c16384_i64 valid_row = %tile_row1 valid_col = %tile_col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>

    pto.tadd ins(%a, %b : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.tadd ins(%tmp0, %c : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%out : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.tstore ins(%out : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x32x32xf32>)
    return
  }

  func.func @fusion_low_level_loop_dynamic_tadd_tmul_trowsum(
      %vrow: index,
      %vcol: index) {
    %c32 = arith.constant 32 : index
    %row0 = arith.minsi %vrow, %c32 : index
    %col0 = arith.minsi %vcol, %c32 : index
    %row1 = arith.minsi %vrow, %c32 : index
    %col1 = arith.minsi %vcol, %c32 : index
    %c0_i64 = arith.constant 0 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c12288_i64 = arith.constant 12288 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c20480_i64 = arith.constant 20480 : i64
    %c24576_i64 = arith.constant 24576 : i64

    %lhs = pto.alloc_tile addr = %c0_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %rhs = pto.alloc_tile addr = %c4096_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %scale = pto.alloc_tile addr = %c8192_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %add = pto.alloc_tile addr = %c12288_i64 valid_row = %row0 valid_col = %col0 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %mul = pto.alloc_tile addr = %c16384_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %reduce_tmp = pto.alloc_tile addr = %c20480_i64 valid_row = %row1 valid_col = %col1 : !pto.tile_buf<vec, 32x32xf32, valid=?x?>
    %reduce = pto.alloc_tile addr = %c24576_i64 valid_row = %row1 : !pto.tile_buf<vec, 32x8xf32, valid=?x1>

    pto.tadd ins(%lhs, %rhs : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%add : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.tmul ins(%add, %scale : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%mul : !pto.tile_buf<vec, 32x32xf32, valid=?x?>)
    pto.trowsum ins(%mul, %reduce_tmp : !pto.tile_buf<vec, 32x32xf32, valid=?x?>, !pto.tile_buf<vec, 32x32xf32, valid=?x?>) outs(%reduce : !pto.tile_buf<vec, 32x8xf32, valid=?x1>)
    return
  }
}

// CHECK: // -----// IR Dump After PTOLowLevelLoopFusion (pto-low-level-loop-fusion) //----- //
// CHECK-LABEL: func.func @fusion_low_level_loop_dynamic_shape(
// CHECK-SAME: %[[VROW:arg[0-9]+]]: index
// CHECK-SAME: %[[VCOL:arg[0-9]+]]: index
// CHECK: %[[ROW_BOUND:.*]] = arith.minsi %[[VROW]],
// CHECK-NEXT: %[[COL_BOUND:.*]] = arith.minsi %[[VCOL]],
// CHECK: %[[REGION:.*]] = pto.fusion_region {
// CHECK: scf.for {{.*}} to %[[ROW_BOUND]] step
// CHECK-NEXT: %{{.*}} = arith.index_cast %[[COL_BOUND]] : index to i32
// CHECK-NEXT: %{{.*}} = arith.index_cast %[[COL_BOUND]] : index to i32
// CHECK-NEXT: %{{.*}} = arith.index_cast %[[COL_BOUND]] : index to i32
// CHECK-NEXT: %{{.*}}:3 = scf.for {{.*}} to %[[COL_BOUND]] step {{.*}} -> (i32, i32, i32) {
// CHECK: %[[ADD0:.*]] = pto.vadd
// CHECK-NEXT: %{{.*}} = arith.subi
// CHECK-NEXT: %[[STORE0:.*]] = memref.subview
// CHECK-NEXT: pto.vsts %[[ADD0]], %[[STORE0]]
// CHECK: %[[ADD1:.*]] = pto.vadd
// CHECK-NEXT: %{{.*}} = arith.subi
// CHECK-NEXT: %[[STORE1:.*]] = memref.subview
// CHECK-NEXT: pto.vsts %[[ADD1]], %[[STORE1]]
// CHECK: %[[ADD2:.*]] = pto.vadd
// CHECK-NEXT: %{{.*}} = arith.subi
// CHECK-NEXT: %[[STORE2:.*]] = memref.subview
// CHECK-NEXT: pto.vsts %[[ADD2]], %[[STORE2]]
// CHECK: }
// CHECK: pto.yield(%{{.*}}) : (!pto.tile_buf<vec, 32x32xf32, valid=?x?>) -> ()
// CHECK: pto.copy_ubuf_to_gm

// CHECK-LABEL: func.func @fusion_low_level_loop_computed_dynamic_shape(
// CHECK-SAME: %[[VROW2:arg[0-9]+]]: index
// CHECK-SAME: %[[VCOL2:arg[0-9]+]]: index
// CHECK: %[[ROW_CMP:.*]] = arith.cmpi ule, %[[VROW2]],
// CHECK-NEXT: %[[COL_CMP:.*]] = arith.cmpi ule, %[[VCOL2]],
// CHECK-NEXT: %[[TILE_ROW:.*]] = arith.select %[[ROW_CMP]], %[[VROW2]],
// CHECK-NEXT: %[[TILE_COL:.*]] = arith.select %[[COL_CMP]], %[[VCOL2]],
// CHECK: %[[REGION2:.*]] = pto.fusion_region {
// CHECK: scf.for {{.*}} to %[[TILE_ROW]] step
// CHECK-NEXT: %{{.*}} = arith.index_cast %[[TILE_COL]] : index to i32
// CHECK-NEXT: %{{.*}} = arith.index_cast %[[TILE_COL]] : index to i32
// CHECK-NEXT: %{{.*}}:2 = scf.for {{.*}} to %[[TILE_COL]] step {{.*}} -> (i32, i32) {
// CHECK: %[[CADD0:.*]] = pto.vadd
// CHECK-NEXT: %{{.*}} = arith.subi
// CHECK-NEXT: %[[CSTORE0:.*]] = memref.subview
// CHECK-NEXT: pto.vsts %[[CADD0]], %[[CSTORE0]]
// CHECK: %[[CADD1:.*]] = pto.vadd
// CHECK-NEXT: %{{.*}} = arith.subi
// CHECK-NEXT: %[[CSTORE1:.*]] = memref.subview
// CHECK-NEXT: pto.vsts %[[CADD1]], %[[CSTORE1]]
// CHECK: }
// CHECK: pto.yield(%{{.*}}) : (!pto.tile_buf<vec, 32x32xf32, valid=?x?>) -> ()
// CHECK: pto.copy_ubuf_to_gm

// CHECK-LABEL: func.func @fusion_low_level_loop_dynamic_tadd_tmul_trowsum(
// CHECK-SAME: %[[RROW:arg[0-9]+]]: index
// CHECK-SAME: %[[RCOL:arg[0-9]+]]: index
// CHECK: %[[RROW_BOUND:.*]] = arith.minsi %[[RROW]],
// CHECK-NEXT: %[[RCOL_BOUND:.*]] = arith.minsi %[[RCOL]],
// CHECK: pto.fusion_region {
// Elementwise + reduce fused into one row loop with iter_args.
// CHECK: scf.for {{.*}} to %[[RROW_BOUND]] step {{.*}} iter_args
// Inner col loop carries reduce accumulator (vreg).
// CHECK: %{{.*}}:4 = scf.for {{.*}} to %[[RCOL_BOUND]] step {{.*}} iter_args({{.*}}, {{.*}}, {{.*}}, {{.*}}) -> (i32, i32, i32, !pto.vreg<64xf32>) {
// CHECK: %[[RADD:.*]] = pto.vadd
// CHECK-NEXT: %{{.*}} = arith.subi
// CHECK-NEXT: %[[RADD_STORE:.*]] = memref.subview
// CHECK-NEXT: pto.vsts %[[RADD]], %[[RADD_STORE]]
// CHECK: %[[RMUL:.*]] = pto.vmul
// CHECK-NEXT: %{{.*}} = arith.subi
// CHECK-NEXT: %[[RMUL_STORE:.*]] = memref.subview
// CHECK-NEXT: pto.vsts %[[RMUL]], %[[RMUL_STORE]]
// Reduce computation inside the same col loop.
// CHECK: pto.vcadd
// CHECK: %{{.*}} = pto.vadd
// CHECK: scf.yield {{.*}} : i32, i32, i32, !pto.vreg<64xf32>
// CHECK: }
// Epilogue: row-reduction result store after inner loop.
// CHECK: pto.vsts
// CHECK: scf.yield {{.*}} : i32
// CHECK: }
// CHECK: pto.yield() : () -> ()
// CHECK: return
