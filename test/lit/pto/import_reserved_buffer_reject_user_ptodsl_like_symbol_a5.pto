// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s
// Guards peer lookup: user-authored symbols containing "__ptodsl_" must not
// be treated as PTODSL ABI specializations unless they carry the logical-name attr.

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "vpto"} {
    func.func @consumer() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
      %peer = pto.import_reserved_buffer {name = "fifo", peer_func = @producer} -> i32
      return
    }
  }

  module attributes {pto.backend = "vpto"} {
    func.func public @producer__ptodsl_user()
        attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
      %buf = pto.reserve_buffer {
        name = "fifo",
        size = 4096,
        location = #pto.address_space<mat>,
        auto = true
      } -> i32
      return
    }
  }
}

// CHECK: error: 'pto.import_reserved_buffer' op expects 'peer_func' to reference an existing func.func
