// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

func.func @tstore_low_precision_a5_invalid(
    %dst: !pto.partition_tensor_view<16x16xf8E5M2>,
    %prequant: i64) {
  %src = pto.declare_tile -> !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
  pto.tstore ins(%src : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>, %prequant : i64)
             outs(%dst : !pto.partition_tensor_view<16x16xf8E5M2>)
  return
}

// CHECK: error: 'pto.tstore' op expects A5 acc preQuantScalar tstore dst type to be i8/ui8/f16/bf16/f32/hif8/f8E4M3
