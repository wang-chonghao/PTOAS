// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

// Verifier coverage for pto.tmov with fp4 packed (f4E2M1x2) low-precision
// tiles on A5. The allowLowPrecision=true path was opened for the A5 tmov
// verifier; this case exercises fp4 packed storage end-to-end through EmitC.

module {
  func.func @tmov_fp4_low_precision_a5_emitc() {
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=!pto.f4E2M1x2, rows=16, cols=32, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=!pto.f4E2M1x2, rows=16, cols=32, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tmov ins(%src : !pto.tile_buf<loc=vec, dtype=!pto.f4E2M1x2, rows=16, cols=32, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             outs(%dst : !pto.tile_buf<loc=vec, dtype=!pto.f4E2M1x2, rows=16, cols=32, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// CHECK: TMOV(
