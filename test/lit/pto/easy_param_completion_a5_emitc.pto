// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

module {
  func.func @mgather_with_explicit_coalesce(
      %mem: memref<1x1x1x8x16xf16, #pto.address_space<gm>>) {
    %idx = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.mgather ins(%mem, %idx : memref<1x1x1x8x16xf16, #pto.address_space<gm>>, !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%dst : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               {coalesce = #pto<coalesce elem>, gatherOob = #pto<gather_oob zero>}
    return
  }

  func.func @mscatter_with_explicit_conflict(
      %mem: memref<1x1x1x8x16xf16, #pto.address_space<gm>>) {
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %idx = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.mscatter ins(%src, %idx : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                 outs(%mem : memref<1x1x1x8x16xf16, #pto.address_space<gm>>)
                 {coalesce = #pto<coalesce elem>, scatterConflict = #pto<scatter_conflict last>}
    return
  }

  func.func @thistogram_with_byte() {
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=ui32, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %idx = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=ui8, rows=1, cols=32, v_row=1, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=ui32, rows=8, cols=256, v_row=8, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.thistogram ins(%src, %idx : !pto.tile_buf<loc=vec, dtype=ui32, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=ui8, rows=1, cols=32, v_row=1, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                   outs(%dst : !pto.tile_buf<loc=vec, dtype=ui32, rows=8, cols=256, v_row=8, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                   {byte = 3 : i32}
    return
  }

}

// CHECK: MGATHER<pto::Coalesce::Elem, pto::GatherOOB::Zero>({{.*}}, {{.*}}, {{.*}})
// CHECK: MSCATTER<pto::Coalesce::Elem, pto::ScatterAtomicOp::None, pto::ScatterOOB::Undefined, pto::ScatterConflict::Last>({{.*}}, {{.*}}, {{.*}})
// CHECK: THISTOGRAM<HistByte::BYTE_3>({{.*}}, {{.*}}, {{.*}})
