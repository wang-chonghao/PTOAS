// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s --check-prefix=A5
// RUN: not ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s --check-prefix=A3ERR

module attributes {"pto.device-spec" = "Ascend910B3"} {
  func.func @tquant_mxfp8() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %src = memref.alloc() : memref<32x32xf32, #pto.address_space<vec>>
    %exp = memref.alloc() : memref<1x32xui8, #pto.address_space<vec>>
    %max = memref.alloc() : memref<1x32xf32, #pto.address_space<vec>>
    %scaling = memref.alloc() : memref<1x32xf32, #pto.address_space<vec>>
    %dst = memref.alloc() : memref<32x32xui8, #pto.address_space<vec>>

    pto.tquant.mx ins(%src : memref<32x32xf32, #pto.address_space<vec>>)
                  outs(%dst, %exp, %max, %scaling :
                       memref<32x32xui8, #pto.address_space<vec>>,
                       memref<1x32xui8, #pto.address_space<vec>>,
                       memref<1x32xf32, #pto.address_space<vec>>,
                       memref<1x32xf32, #pto.address_space<vec>>)
                  {quant_type = #pto<quant_type MXFP8>}
    return
  }

  func.func @tquant_mxfp4_nv() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %src = memref.alloc() : memref<32x64xbf16, #pto.address_space<vec>>
    %exp = memref.alloc() : memref<1x64xui8, #pto.address_space<vec>>
    %max = memref.alloc() : memref<1x64xbf16, #pto.address_space<vec>>
    %scaling = memref.alloc() : memref<1x64xbf16, #pto.address_space<vec>>
    %dst = memref.alloc() : memref<32x32x!pto.f4E2M1x2, #pto.address_space<vec>>

    pto.tquant.mx ins(%src : memref<32x64xbf16, #pto.address_space<vec>>)
                  outs(%dst, %exp, %max, %scaling :
                       memref<32x32x!pto.f4E2M1x2, #pto.address_space<vec>>,
                       memref<1x64xui8, #pto.address_space<vec>>,
                       memref<1x64xbf16, #pto.address_space<vec>>,
                       memref<1x64xbf16, #pto.address_space<vec>>)
                  {quant_type = #pto<quant_type MXFP4_E2M1>,
                   quantScaleAlg = #pto<quant_scale_alg nv>}
    return
  }

  func.func @tquant_mxfp8_nz() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %src = memref.alloc() : memref<32x32xf32, #pto.address_space<vec>>
    %exp = memref.alloc() : memref<1x32xui8, #pto.address_space<vec>>
    %max = memref.alloc() : memref<1x32xf32, #pto.address_space<vec>>
    %scaling = memref.alloc() : memref<1x32xf32, #pto.address_space<vec>>
    %exp_zz = memref.alloc() : memref<1x32xui8, #pto.address_space<vec>>
    %dst = memref.alloc() : memref<32x32xui8, #pto.address_space<vec>>

    pto.tquant.mx ins(%src : memref<32x32xf32, #pto.address_space<vec>>)
                  outs(%dst, %exp, %max, %scaling, %exp_zz :
                       memref<32x32xui8, #pto.address_space<vec>>,
                       memref<1x32xui8, #pto.address_space<vec>>,
                       memref<1x32xf32, #pto.address_space<vec>>,
                       memref<1x32xf32, #pto.address_space<vec>>,
                       memref<1x32xui8, #pto.address_space<vec>>)
                  {quant_type = #pto<quant_type MXFP8>,
                   storeMode = #pto<vec_store_mode nz>}
    return
  }
}

// A5-LABEL: AICORE void tquant_mxfp8(
// A5: TQUANT<pto::QuantType::MXFP8
// A5-SAME: >(
// A5-LABEL: AICORE void tquant_mxfp4_nv(
// A5: TQUANT<pto::QuantType::MXFP4_E2M1
// A5-SAME: pto::QuantScaleAlg::NV
// A5-LABEL: AICORE void tquant_mxfp8_nz(
// A5: TQUANT<pto::QuantType::MXFP8, pto::VecStoreMode::NZ
// A3ERR: error: 'pto.tquant.mx' op tquant.mx is only supported on A5
