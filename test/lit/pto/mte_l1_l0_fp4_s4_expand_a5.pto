// Guard: fp4 packed L1->L0 wrapper loads must lower through the `_s4` raw
// bridge ops, with K coordinates converted to s4 units instead of byte-path
// defaults.
// RUN: ptoas --pto-arch=a5 --pto-level=level3 --pto-backend=vpto --emit-vpto --mlir-print-ir-after=vpto-expand-wrapper-ops %s -o /dev/null 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @fp4_mte_l1_l0_expand(
      %src_l1_a: memref<?x!pto.f4E2M1x2, #pto.address_space<mat>>,
      %src_l1_b: memref<?x!pto.f4E2M1x2, #pto.address_space<mat>>,
      %dst_l0a: memref<?x!pto.f4E2M1x2, #pto.address_space<left>>,
      %dst_l0b: memref<?x!pto.f4E2M1x2, #pto.address_space<right>>) attributes {pto.kernel} {
    %c0_i64 = arith.constant 0 : i64
    %c64_i64 = arith.constant 64 : i64
    pto.mte_l1_l0a %src_l1_a, %dst_l0a, %c64_i64, %c64_i64, %c0_i64, %c0_i64
      : memref<?x!pto.f4E2M1x2, #pto.address_space<mat>>, memref<?x!pto.f4E2M1x2, #pto.address_space<left>>, i64, i64, i64, i64
    pto.mte_l1_l0b %src_l1_b, %dst_l0b, %c64_i64, %c64_i64, %c0_i64, %c0_i64 {transpose = true}
      : memref<?x!pto.f4E2M1x2, #pto.address_space<mat>>, memref<?x!pto.f4E2M1x2, #pto.address_space<right>>, i64, i64, i64, i64
    return
  }
}

// CHECK-LABEL: func.func @fp4_mte_l1_l0_expand
// CHECK: pto.load_cbuf_to_ca_s4 {{.*}}, %c0_i64{{.*}}, %c0_i64{{.*}}, %c4_i64{{.*}}, %c1_i64{{.*}}, %c4_i64{{.*}}, %c4_i64{{.*}}, %c0_i64
// CHECK: pto.load_cbuf_to_cb_s4 {{.*}}, %c0_i64{{.*}}, %c0_i64{{.*}}, %c4_i64{{.*}}, %c1_i64{{.*}}, %c4_i64{{.*}}, %c4_i64{{.*}}, %c1_i64
