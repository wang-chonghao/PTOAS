// Guards backend-helper inlining when functions live inside a nested child module.
// RUN: ptoas --pto-arch=a5 --mlir-print-ir-after=pto-inline-backend-helpers %s -o /dev/null 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  module {
    func.func @kernel(%arg0: i32) {
      %0 = func.call @ptodsl_simd_helper(%arg0) : (i32) -> i32
      %1 = func.call @regular_passthrough(%0) : (i32) -> i32
      return
    }

    func.func private @ptodsl_simd_helper(%x: i32) -> i32 attributes {pto.ptodsl.subkernel_helper = "simd"} {
      %c1 = arith.constant 1 : i32
      %y = arith.addi %x, %c1 : i32
      return %y : i32
    }

    func.func private @regular_passthrough(%x: i32) -> i32 {
      return %x : i32
    }
  }
}

// CHECK-LABEL: module {
// CHECK: func.func @kernel
// CHECK: arith.constant 1 : i32
// CHECK: arith.addi %arg0, %{{[^,]+}} : i32
// CHECK-NOT: func.call @ptodsl_simd_helper
// CHECK: call @regular_passthrough
// CHECK-NOT: func.func private @ptodsl_simd_helper
// CHECK: func.func private @regular_passthrough
