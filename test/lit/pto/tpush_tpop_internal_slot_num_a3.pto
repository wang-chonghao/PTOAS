// RUN: ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s --check-prefix=A3

module {
  func.func @cube_kernel(%gm_slot_buffer: memref<256xf32, #pto.address_space<gm>>,
                         %c2v_consumer_buf: i32)
      attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %pipe = pto.initialize_l2g2l_pipe {
      dir_mask = 1,
      slot_size = 1024,
      slot_num = 2,
      local_slot_num = 1,
      flag_base = 0
    }(%gm_slot_buffer : memref<256xf32, #pto.address_space<gm>>,
      %c2v_consumer_buf : i32) -> !pto.pipe
    return
  }
}

// A3-LABEL: AICORE void cube_kernel(
// A3: auto {{v[0-9]+}} = TPipe<0, Direction::DIR_C2V, 1024, 2, 1, false>(
