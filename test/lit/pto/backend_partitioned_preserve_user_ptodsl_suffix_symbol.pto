// RUN: ptoas --cann-output-version=9.0.0 --pto-arch=a5 --emit-pto-ir %s -o - 2>&1 | FileCheck %s
// Guards child-unit rewriting: user-authored symbols containing "__ptodsl_"
// must not be rewritten into logical-name wrappers. Check the emitted PTO IR
// directly so the test stays toolchain-free and does not require fatobj output.

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "emitc"} {
    func.func private @helper__ptodsl_user()

    func.func @entry() attributes {pto.entry} {
      func.call @helper__ptodsl_user() : () -> ()
      return
    }
  }

  module attributes {pto.backend = "emitc"} {
    func.func public @helper() {
      return
    }

    func.func public @helper__ptodsl_user() {
      return
    }
  }
}

// CHECK-LABEL: module attributes {pto.backend = "emitc", pto.target_arch = "a5"} {
// CHECK: module attributes {pto.backend = "emitc"} {
// CHECK: func.func private @helper__ptodsl_user()
// CHECK: func.func @entry() attributes {pto.entry} {
// CHECK: call @helper__ptodsl_user() : () -> ()
// CHECK: return
// CHECK: module attributes {pto.backend = "emitc"} {
// CHECK: func.func public @helper() {
// CHECK-NEXT: return
// CHECK-NEXT: }
// CHECK-NEXT: func.func public @helper__ptodsl_user() {
// CHECK-NEXT: return
// CHECK-NEXT: }
