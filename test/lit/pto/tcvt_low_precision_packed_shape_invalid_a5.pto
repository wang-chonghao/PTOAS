// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

func.func @tcvt_low_precision_packed_shape_invalid_a5() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
  %src = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
  %dst = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=!pto.f4E1M2x2, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
  pto.tcvt ins(%src : !pto.tile_buf<loc=vec, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
           outs(%dst : !pto.tile_buf<loc=vec, dtype=!pto.f4E1M2x2, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
  return
}

// CHECK: error: 'pto.tcvt' op expects src and dst to have compatible shapes
