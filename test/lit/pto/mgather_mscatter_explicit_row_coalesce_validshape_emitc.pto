// RUN: ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s --check-prefix=A3

module {
  func.func @mgather_explicit_row_coalesce_validshape(
      %mem: memref<1x1x1x8x16xf16, #pto.address_space<gm>>) {
    %idx = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=8, v_row=1, v_col=8,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.mgather ins(%mem, %idx
        : memref<1x1x1x8x16xf16, #pto.address_space<gm>>,
          !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=8, v_row=1, v_col=8,
                        blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      outs(%dst
        : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16,
                        blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      {coalesce = #pto<coalesce row>, gatherOob = #pto<gather_oob zero>}
    return
  }

  func.func @mscatter_explicit_row_coalesce_validshape(
      %mem: memref<1x1x1x8x16xf16, #pto.address_space<gm>>) {
    %src = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %idx = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=8, v_row=1, v_col=8,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.mscatter ins(%src, %idx
        : !pto.tile_buf<loc=vec, dtype=f16, rows=8, cols=16, v_row=8, v_col=16,
                        blayout=row_major, slayout=none_box, fractal=512, pad=0>,
          !pto.tile_buf<loc=vec, dtype=i32, rows=8, cols=8, v_row=1, v_col=8,
                        blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      outs(%mem : memref<1x1x1x8x16xf16, #pto.address_space<gm>>)
      {coalesce = #pto<coalesce row>, scatterOob = #pto<scatter_oob skip>}
    return
  }
}

// A3: MGATHER<pto::Coalesce::Row, pto::GatherOOB::Zero>({{.*}}, {{.*}}, {{.*}})
// A3: MSCATTER<pto::Coalesce::Row, pto::ScatterAtomicOp::None, pto::ScatterOOB::Skip>({{.*}}, {{.*}}, {{.*}})
