// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s --check-prefix=A5

module attributes {pto.target_arch = "a5"} {
  func.func @tget_scale_addr_emitc(%src : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=1, cols=128, v_row=1, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>) {
    %dst = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=1, cols=4, v_row=1, v_col=4, blayout=row_major, slayout=row_major, fractal=32, pad=0>

    pto.tget_scale_addr ins(%src : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=1, cols=128, v_row=1, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
                        outs(%dst : !pto.tile_buf<loc=scaling, dtype=f16, rows=1, cols=4, v_row=1, v_col=4, blayout=row_major, slayout=row_major, fractal=32, pad=0>)
    return
  }
}

// A5: GetScaleAddr
