// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s --check-prefix=A5

module attributes {pto.target_arch = "a5"} {
  func.func @tmatmul_mx_cross_family_invalid() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %lhs = pto.alloc_tile : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=16, cols=512, v_row=16, v_col=512, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %rhs = pto.alloc_tile : !pto.tile_buf<loc=right, dtype=!pto.f4E1M2x2, rows=512, cols=16, v_row=512, v_col=16, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %a_scale = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %b_scale = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %dst = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    pto.tmatmul.mx ins(%lhs, %a_scale, %rhs, %b_scale : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=16, cols=512, v_row=16, v_col=512, blayout=col_major, slayout=row_major, fractal=512, pad=0>, !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=row_major, fractal=32, pad=0>, !pto.tile_buf<loc=right, dtype=!pto.f4E1M2x2, rows=512, cols=16, v_row=512, v_col=16, blayout=row_major, slayout=col_major, fractal=512, pad=0>, !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=col_major, fractal=32, pad=0>) outs(%dst : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
    return
  }
}

// A5: expects A5 mx lhs/rhs element types to be a supported fp8/fp8 or fp4/fp4 pair
