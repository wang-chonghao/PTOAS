// Integer path: pto-isa TPowI does not consume tmp, so tmp must be omitted.
// RUN: ptoas --pto-arch=a3 --mlir-print-ir-after=pto-view-to-memref %s 2>&1 | FileCheck %s --check-prefix=A3

module {
  func.func @tpow_int_no_tmp() {
    %base = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %exp  = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst  = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tpow ins(%base, %exp : !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%dst : !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// A3: pto.tpow ins({{.*}}, {{.*}} : memref<1x16xi32
// A3-NOT: , {{.*}} : memref<1x16xi32{{[^,]*}}, memref<1x16xi32{{[^,]*}}, memref<1x16xi32
// A3: TPOW([[VDST:v[0-9]+]], [[VBASE:v[0-9]+]], [[VEXP:v[0-9]+]]);
