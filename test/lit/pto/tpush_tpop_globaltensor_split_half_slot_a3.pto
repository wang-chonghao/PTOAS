//
// Guards split-half-slot globaltensor GM-slot pipes on A3 so split consumers
// keep the reduced entry shape while reusing the original slot strides.
//
// RUN: ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s

module {
  func.func @call_both(%ffts : memref<256xi64>, %fifo_mem : !pto.ptr<f32>)
      attributes {pto.entry} {
    pto.set_ffts %ffts : memref<256xi64>
    func.call @cube_kernel(%fifo_mem) : (!pto.ptr<f32>) -> ()
    func.call @vector_kernel(%fifo_mem) : (!pto.ptr<f32>) -> ()
    return
  }

  func.func @cube_kernel(%fifo_mem : !pto.ptr<f32>)
      attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c1 = arith.constant 1 : index
    %c4 = arith.constant 4 : index
    %c128 = arith.constant 128 : index
    %c16384 = arith.constant 16384 : index

    %slot_desc = pto.make_tensor_view %fifo_mem,
      shape = [%c4, %c128, %c128], strides = [%c16384, %c128, %c1]
      : !pto.tensor_view<4x128x128xf32>
    pto.aic_initialize_pipe {id = 0, dir_mask = 1, slot_size = 262144}
      (gm_slot_tensor = %slot_desc : !pto.tensor_view<4x128x128xf32>)

    %entry = pto.talloc_to_aiv {id = 0, split = 1}
      -> !pto.tensor_view<4x128x128xf32>
    pto.tpush_to_aiv(%entry : !pto.tensor_view<4x128x128xf32>) {id = 0, split = 1}
    func.return
  }

  func.func @vector_kernel(%fifo_mem : !pto.ptr<f32>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c4 = arith.constant 4 : index
    %c16 = arith.constant 16 : index
    %c64 = arith.constant 64 : index
    %c128 = arith.constant 128 : index
    %c16384 = arith.constant 16384 : index
    %slot_desc = pto.make_tensor_view %fifo_mem,
      shape = [%c4, %c64, %c128], strides = [%c16384, %c128, %c1]
      : !pto.tensor_view<4x64x128xf32>
    pto.aiv_initialize_pipe {id = 0, dir_mask = 1, slot_size = 262144}
      (gm_slot_tensor = %slot_desc : !pto.tensor_view<4x64x128xf32>)

    %entry = pto.tpop_from_aic {id = 0, split = 1}
      -> !pto.tensor_view<4x64x128xf32>
    %part = pto.partition_view %entry,
      offsets = [%c0, %c0, %c0], sizes = [%c4, %c16, %c128]
      : !pto.tensor_view<4x64x128xf32> -> !pto.partition_tensor_view<4x16x128xf32>
    %tile = pto.alloc_tile
      : !pto.tile_buf<vec, 64x128xf32>
    pto.tload ins(%part : !pto.partition_tensor_view<4x16x128xf32>)
              outs(%tile : !pto.tile_buf<vec, 64x128xf32>)
    pto.tfree_from_aic(%entry : !pto.tensor_view<4x64x128xf32>) {id = 0, split = 1}
    func.return
  }
}

// CHECK-LABEL: AICORE void cube_kernel
// CHECK: TPipe<0, Direction::DIR_C2V, 262144, 8, 8, false>
// CHECK: TALLOC<TPipe<0, Direction::DIR_C2V, 262144, 8, 8, false>, GlobalTensor<float, pto::Shape<1, 1, 4, 128, 128>, pto::Stride<65536, 65536, 16384, 128, 1>, pto::Layout::ND>, TileSplitAxis::TILE_UP_DOWN>
// CHECK-LABEL: AICORE void vector_kernel
// CHECK: TPipe<0, Direction::DIR_C2V, 262144, 8, 8, false>
// CHECK: TPOP<TPipe<0, Direction::DIR_C2V, 262144, 8, 8, false>, GlobalTensor<float, pto::Shape<1, 1, 4, 64, 128>, pto::Stride<65536, 65536, 16384, 128, 1>, pto::Layout::ND>, TileSplitAxis::TILE_UP_DOWN>
// CHECK: GlobalTensor<float, pto::Shape<1, 1, 4, 16, 128>, pto::Stride<65536, 65536, 16384, 128, 1>, pto::Layout::ND>
// CHECK: TFREE<TPipe<0, Direction::DIR_C2V, 262144, 8, 8, false>, GlobalTensor<float, pto::Shape<1, 1, 4, 64, 128>, pto::Stride<65536, 65536, 16384, 128, 1>, pto::Layout::ND>, TileSplitAxis::TILE_UP_DOWN>
// CHECK-LABEL: __global__ AICORE void call_both
// CHECK: set_ffts_base_addr
// CHECK: cube_kernel
// CHECK: vector_kernel
