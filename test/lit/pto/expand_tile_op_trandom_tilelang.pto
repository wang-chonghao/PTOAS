// RUN: ptoas --pto-arch=a5 --emit-pto-ir %s -o - | FileCheck %s
// CHECK-LABEL: func.func @TRandom_test

// Test template for pto.trandom operator
// 
// NOTE: pto.trandom uses Philox random number generation.
// It requires special operations (vci, vmull, vbr) that may not be 
// fully supported in current TileLang DSL without extension.
//
// This test file demonstrates expected IR structure.

module {
  func.func @TRandom_test() {
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %seed = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=8, v_row=1, v_col=2,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %counter = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=8, v_row=1, v_col=4,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>

    // Note: pto.trandom may not be defined in current PTO IR
    // This shows expected usage pattern when available
    
    return
  }
}
