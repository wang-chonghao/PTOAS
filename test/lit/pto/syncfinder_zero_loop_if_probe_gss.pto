// RUN: ptoas --pto-arch=a3 --pto-level=level3 --enable-graph-sync-solver --graph-sync-solver-event-id-max=64 %s | FileCheck %s
//
// The loop may execute zero iterations. If InsertSyncAnalysis reuses
// syncFinder learned from the loop body for the post-loop TMOV, the matching
// wait must be moved before the loop so the zero-trip path is still ordered.
//
// CHECK-LABEL: AICORE void syncfinder_zero_loop_if_probe
// CHECK: TLOAD
// CHECK: set_flag(PIPE_MTE2, PIPE_V, EVENT_ID[[LOOP:[0-9]+]]);
// CHECK-NEXT: wait_flag(PIPE_MTE2, PIPE_V, EVENT_ID[[LOOP]]);
// CHECK-NEXT: for (size_t
// CHECK: if ((int64_t)
// CHECK: TMOV
// CHECK: }
// CHECK: }
// CHECK: TMOV

module attributes {pto.target_arch = "a2a3"} {
  func.func @syncfinder_zero_loop_if_probe(%arg0: !pto.ptr<f32>, %arg1: index) attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0_i64 = arith.constant 0 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c0_index = arith.constant 0 : index
    %c1_index = arith.constant 1 : index
    %c8_index = arith.constant 8 : index
    %c128_index = arith.constant 128 : index

    %view = pto.make_tensor_view %arg0, shape = [%c8_index, %c128_index], strides = [%c128_index, %c1_index] {layout = #pto.layout<nd>}: !pto.tensor_view<?x?xf32>
    %pview = pto.partition_view %view, offsets = [%c0_index, %c0_index], sizes = [%c8_index, %c128_index] : !pto.tensor_view<?x?xf32> -> !pto.partition_tensor_view<8x128xf32>

    %src = pto.alloc_tile addr = %c0_i64 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tload ins(%pview : !pto.partition_tensor_view<8x128xf32>) outs(%src : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    scf.for %i = %c1_index to %arg1 step %c1_index {
      %take = arith.cmpi eq, %i, %c1_index : index
      scf.if %take {
        %loop_dst = pto.alloc_tile addr = %c4096_i64 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>
        pto.tmov ins(%src : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%loop_dst : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      }
    }

    %post_dst = pto.alloc_tile addr = %c8192_i64 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tmov ins(%src : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%post_dst : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=128, v_row=8, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}
