// RUN: not ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s

func.func @tprefetch_low_precision_memref_invalid_a3(
    %src: memref<16x16x!pto.hif8, #pto.address_space<gm>>,
    %dst: memref<16x16xi8, #pto.address_space<vec>>) {
  pto.tprefetch ins(%src : memref<16x16x!pto.hif8, #pto.address_space<gm>>)
                outs(%dst : memref<16x16xi8, #pto.address_space<vec>>)
  return
}

// CHECK: error: 'pto.tprefetch' op expects A2/A3 tprefetch low-precision element types to be unsupported
