// RUN: ptoas --pto-arch=a5 --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @alloc_tile_low_precision_valid() {
    %0 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=!pto.hif8, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %1 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=!pto.f4E1M2x2, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %2 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f8E4M3FN, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    return
  }
}

// CHECK: func.func @alloc_tile_low_precision_valid()
// CHECK-NOT: pto.alloc_tile
