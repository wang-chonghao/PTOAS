// RUN: ptoas --pto-arch=a5 --emit-pto-ir %s | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @kernel() {
    func.call @simd_helper() : () -> ()
    func.return
  }

  func.func private @simd_helper() attributes {pto.ptodsl.subkernel_helper = "simd"} {
    pto.section.vector {
      func.call @local_helper() : () -> ()
    }
    func.return
  }

  func.func private @local_helper() {
    pto.section.vector {
    }
    func.return
  }
}

// CHECK: func.func private @simd_helper
// CHECK: func.call @local_helper
