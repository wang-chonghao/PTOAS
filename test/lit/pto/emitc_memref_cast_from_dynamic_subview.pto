// Guards EmitC lowering for memref.cast left by dynamic partition-view paths.
// RUN: ptoas --pto-arch=a3 --enable-insert-sync %s -o - 2>&1 | FileCheck %s

module {
  func.func @emitc_memref_cast_from_dynamic_subview(%src: !pto.ptr<f32, gm>,
                                                   %dst: !pto.ptr<f32, gm>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c32 = arith.constant 32 : index
    %src_view = pto.make_tensor_view %src, shape = [%c32, %c32],
      strides = [%c32, %c1] : !pto.tensor_view<?x?xf32>
    %dst_view = pto.make_tensor_view %dst, shape = [%c32, %c32],
      strides = [%c32, %c1] : !pto.tensor_view<?x?xf32>
    %rows = pto.get_tensor_view_dim %src_view, %c0
      : !pto.tensor_view<?x?xf32> -> index
    %cols = pto.get_tensor_view_dim %src_view, %c1
      : !pto.tensor_view<?x?xf32> -> index
    %src_part = pto.partition_view %src_view, offsets = [%c0, %c0],
      sizes = [%rows, %cols]
      : !pto.tensor_view<?x?xf32> -> !pto.partition_tensor_view<32x32xf32>
    %in = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %out = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    pto.tload ins(%src_part : !pto.partition_tensor_view<32x32xf32>)
              outs(%in : !pto.tile_buf<vec, 32x32xf32>)
    pto.tabs ins(%in : !pto.tile_buf<vec, 32x32xf32>)
             outs(%out : !pto.tile_buf<vec, 32x32xf32>)
    %dst_part = pto.partition_view %dst_view, offsets = [%c0, %c0],
      sizes = [%c32, %c32] : !pto.tensor_view<?x?xf32>
    pto.tstore ins(%out : !pto.tile_buf<vec, 32x32xf32>)
               outs(%dst_part : !pto.partition_tensor_view<32x32xf32>)
    return
  }
}

// CHECK-LABEL: AICORE void emitc_memref_cast_from_dynamic_subview
// CHECK: TLOAD(
// CHECK: TABS(
// CHECK: TSTORE(
// CHECK-NOT: failed to legalize operation 'memref.cast'
