// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s --check-prefix=A5

module attributes {pto.target_arch = "a5"} {
  func.func @tmatmul_mx_f8e5m2_emitc(%a : !pto.tile_buf<loc=left, dtype=f8E5M2, rows=16, cols=512, v_row=16, v_col=512, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                                     %b : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=512, cols=32, v_row=512, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %a_scale = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %b_scale = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %dst = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>

    pto.tmatmul.mx ins(%a, %a_scale, %b, %b_scale : !pto.tile_buf<loc=left, dtype=f8E5M2, rows=16, cols=512, v_row=16, v_col=512, blayout=col_major, slayout=row_major, fractal=512, pad=0>, !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=row_major, fractal=32, pad=0>, !pto.tile_buf<loc=right, dtype=f8E5M2, rows=512, cols=32, v_row=512, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>, !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=col_major, fractal=32, pad=0>) outs(%dst : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=32, v_row=16, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
    return
  }
}

// A5: TMATMUL_MX([[D0:v[0-9]+]], [[A0:v[0-9]+]], [[AS0:v[0-9]+]], [[B0:v[0-9]+]], [[BS0:v[0-9]+]]);
