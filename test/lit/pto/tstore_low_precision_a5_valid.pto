// RUN: ptoas --pto-arch=a5 --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @tstore_low_precision_a5_valid(
      %vec_dst: !pto.partition_tensor_view<16x16xf8E4M3FN>,
      %acc_dst: !pto.partition_tensor_view<16x16x!pto.hif8>,
      %prequant: i64) {
    %vec_src = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=f8E4M3FN, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %acc_src = pto.declare_tile -> !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>

    pto.tstore ins(%vec_src : !pto.tile_buf<loc=vec, dtype=f8E4M3FN, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%vec_dst : !pto.partition_tensor_view<16x16xf8E4M3FN>)
    pto.tstore ins(%acc_src : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>, %prequant : i64)
               outs(%acc_dst : !pto.partition_tensor_view<16x16x!pto.hif8>)
    return
  }
}

// CHECK: func.func @tstore_low_precision_a5_valid(%arg0: memref<16x16xf8E4M3FN>, %arg1: memref<16x16x!pto.hif8>, %arg2: i64)
// CHECK: pto.bind_tile
// CHECK: pto.section.vector {
// CHECK: pto.tstore ins(
// CHECK: outs(%arg0 : memref<16x16xf8E4M3FN>)
// CHECK: }
// CHECK: pto.section.cube {
// CHECK: pto.tstore ins(
// CHECK: outs(%arg1 : memref<16x16x!pto.hif8>)
// CHECK: }
