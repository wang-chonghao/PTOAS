// RUN: ptoas --pto-arch a5 %s | FileCheck %s

module attributes {"pto.device-spec" = "Ascend950"} {
  func.func @tinsert_a5_modes() {
    %c0 = arith.constant 0 : index
    %src = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    %fp = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=1, cols=32, v_row=1, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst0 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst1 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst2 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i8, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src_nz = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %dst_mat = pto.alloc_tile : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>

    pto.tinsert ins(%src, %c0, %c0 : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>, index, index)
                outs(%dst0 : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                {accToVecMode = #pto.acc_to_vec_mode<single_mode_vec0>}

    pto.tinsert ins(%src, %c0, %c0 : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>, index, index)
                outs(%dst1 : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                {accToVecMode = #pto.acc_to_vec_mode<dual_mode_split_m>,
                 reluPreMode = #pto<relu_pre_mode normal_relu>}

    pto.tinsert_fp ins(%src, %fp, %c0, %c0 : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>, !pto.tile_buf<loc=scaling, dtype=f16, rows=1, cols=32, v_row=1, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, index, index)
                   outs(%dst2 : !pto.tile_buf<loc=vec, dtype=i8, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                   {accToVecMode = #pto.acc_to_vec_mode<single_mode_vec1>}

    pto.tinsert ins(%src_nz, %c0, %c0 : !pto.tile_buf<loc=vec, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>, index, index)
                outs(%dst_mat : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
                {tinsertMode = #pto.tinsert_mode<split2>}
    return
  }
}

// CHECK-LABEL: AICORE void tinsert_a5_modes(
// CHECK: TINSERT<{{.*}}pto::AccToVecMode::SingleModeVec0{{.*}}ReluPreMode::NoRelu>([[DST0:[^,]+]], [[SRC:[^,]+]], [[ROW:[^,]+]], [[COL:[^)]+]]);
// CHECK: TINSERT<{{.*}}pto::AccToVecMode::DualModeSplitM{{.*}}ReluPreMode::NormalRelu>([[DST1:[^,]+]], [[SRC]], [[ROW]], [[COL]]);
// CHECK: TINSERT<{{.*}}pto::AccToVecMode::SingleModeVec1{{.*}}ReluPreMode::NoRelu>([[DST2:[^,]+]], [[SRC]], [[FP:[^,]+]], [[ROW]], [[COL]]);
// CHECK: TINSERT<pto::TInsertMode::SPLIT2>([[DSTMAT:[^,]+]], [[SRCNZ:[^,]+]], [[ROW]], [[COL]]);
