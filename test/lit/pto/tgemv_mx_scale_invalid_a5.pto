// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s --check-prefix=A5

module attributes {pto.target_arch = "a5"} {
  func.func @tgemv_mx_full_shape_scale_invalid() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %lhs = pto.alloc_tile : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=1, cols=128, v_row=1, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %rhs = pto.alloc_tile : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=128, cols=32, v_row=128, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %a_scale = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=1, cols=128, v_row=1, v_col=128, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %b_scale = pto.alloc_tile : !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=32, v_row=128, v_col=32, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %dst = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=1, cols=32, v_row=1, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    pto.tgemv.mx ins(%lhs, %a_scale, %rhs, %b_scale : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=1, cols=128, v_row=1, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>, !pto.tile_buf<loc=scaling, dtype=f16, rows=1, cols=128, v_row=1, v_col=128, blayout=row_major, slayout=row_major, fractal=32, pad=0>, !pto.tile_buf<loc=right, dtype=f8E5M2, rows=128, cols=32, v_row=128, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>, !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=32, v_row=128, v_col=32, blayout=col_major, slayout=col_major, fractal=32, pad=0>) outs(%dst : !pto.tile_buf<loc=acc, dtype=f32, rows=1, cols=32, v_row=1, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>)
    return
  }
}

// Expects a_scale shape to be [M, ceil(K/32)]
// A5: error: 'pto.tgemv.mx' op expects a_scale shape/valid_shape to be [M, ceil(K/32)]
