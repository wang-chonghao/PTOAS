// Guards PTODSL subkernel helper arguments restored to tile_buf ABI.
// RUN: ptoas --pto-arch=a5 --pto-level=level3 --mlir-print-ir-after=pto-materialize-tile-handles %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=IR

module {
  func.func @ptodsl_subkernel_helper_tile_abi(
      %arg0: !pto.tile_buf<vec, 16x16xf16>,
      %arg1: !pto.tile_buf<vec, 16x1xf32, blayout=col_major>,
      %arg2: f32) attributes {
        pto.ptodsl.subkernel_helper = "simd"
      } {
    pto.section.vector {
      %0 = pto.tile_buf_addr %arg0
        : !pto.tile_buf<vec, 16x16xf16>
        -> memref<16x16xf16, #pto.address_space<vec>>
      %1 = pto.tile_buf_addr %arg1
        : !pto.tile_buf<vec, 16x1xf32, blayout=col_major>
        -> memref<16x1xf32, #pto.address_space<vec>>
      func.call @ptodsl_subkernel_helper_tile_abi_sink(%0, %1, %arg2)
        : (memref<16x16xf16, #pto.address_space<vec>>,
           memref<16x1xf32, #pto.address_space<vec>>, f32) -> ()
    }
    return
  }

  func.func private @ptodsl_subkernel_helper_tile_abi_sink(
      memref<16x16xf16, #pto.address_space<vec>>,
      memref<16x1xf32, #pto.address_space<vec>>,
      f32)
}

// IR: IR Dump After PTOMaterializeTileHandles
// IR-LABEL: func.func private @ptodsl_subkernel_helper_tile_abi(
// IR-SAME: %{{.*}}: !pto.tile_buf<vec, 16x16xf16>
// IR-SAME: %{{.*}}: !pto.tile_buf<vec, 16x1xf32, blayout=col_major>
// IR-SAME: %{{.*}}: f32
// IR-SAME: attributes
// IR: builtin.unrealized_conversion_cast %{{.*}} : !pto.tile_buf<vec, 16x1xf32, blayout=col_major> to memref<16x1xf32, strided<[1, 16], offset: ?>, #pto.address_space<vec>>
// IR: builtin.unrealized_conversion_cast %{{.*}} : !pto.tile_buf<vec, 16x16xf16> to memref<16x16xf16, strided<[16, 1], offset: ?>, #pto.address_space<vec>>
// IR: pto.tile_buf_addr %{{.*}} : !pto.tile_buf<vec, 16x16xf16>
// IR: pto.tile_buf_addr %{{.*}} : !pto.tile_buf<vec, 16x1xf32, blayout=col_major>
