// RUN: ptoas %s | FileCheck %s
// Guards explicit artifact visibility: public non-entry EmitC functions only
// keep C linkage when they opt into external artifact visibility.

module {
  func.func @entry() attributes {pto.entry} {
    func.call @helper() : () -> ()
    return
  }

  func.func public @helper() attributes {pto.visibility = "external"} {
    return
  }
}

// CHECK-LABEL: extern "C" AICORE void helper(
// CHECK-LABEL: extern "C" __global__ AICORE void entry(
// CHECK: helper();
