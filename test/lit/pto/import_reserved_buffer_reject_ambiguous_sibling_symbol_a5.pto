// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s
// Guards peer lookup: multiple public sibling functions with the same symbol
// must not resolve by silently picking the first outer-module walk match.

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "vpto"} {
    func.func @consumer() {
      %import = pto.import_reserved_buffer {
        name = "fifo",
        peer_func = @producer
      } -> i32
      return
    }
  }

  module attributes {pto.backend = "vpto"} {
    func.func public @producer() {
      %buffer = pto.reserve_buffer {
        name = "fifo",
        size = 4096,
        location = #pto.address_space<vec>,
        auto = true
      } -> i32
      return
    }
  }

  module attributes {pto.backend = "vpto"} {
    func.func public @producer() {
      %buffer = pto.reserve_buffer {
        name = "fifo",
        size = 4096,
        location = #pto.address_space<vec>,
        auto = true
      } -> i32
      return
    }
  }
}

// CHECK: error: 'pto.import_reserved_buffer' op expects 'peer_func' to reference an existing func.func
