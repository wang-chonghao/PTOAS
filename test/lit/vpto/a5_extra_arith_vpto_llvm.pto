// RUN: ptoas --cann-output-version=9.0.0 --pto-arch=a5 --pto-backend=vpto --emit-vpto-llvm-ir %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmadd_f32_store(%acc: !pto.vreg<64xf32>, %lhs: !pto.vreg<64xf32>, %rhs: !pto.vreg<64xf32>, %dst: !pto.ptr<f32, ub>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      %out = pto.vmadd %acc, %lhs, %rhs, %mask : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>
      pto.vsts %out, %dst[%c0], %mask : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
    }
    return
  }

  func.func @vcbmax_vcbmin_i16_store(%input: !pto.vreg<128xsi16>, %dst: !pto.ptr<si16, ub>, %pdst: !pto.ptr<ui8, ub>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
      %max_value, %max_pred = pto.vcbmax %input, %mask : !pto.vreg<128xsi16>, !pto.mask<b16> -> !pto.vreg<128xsi16>, !pto.mask<b16>
      %min_value, %min_pred = pto.vcbmin %input, %mask : !pto.vreg<128xsi16>, !pto.mask<b16> -> !pto.vreg<128xsi16>, !pto.mask<b16>
      pto.vsts %max_value, %dst[%c0], %mask : !pto.vreg<128xsi16>, !pto.ptr<si16, ub>, !pto.mask<b16>
      pto.vsts %min_value, %dst[%c0], %mask : !pto.vreg<128xsi16>, !pto.ptr<si16, ub>, !pto.mask<b16>
      pto.psts %max_pred, %pdst[%c0], "NORM" : !pto.mask<b16>, !pto.ptr<ui8, ub>, index
      pto.psts %min_pred, %pdst[%c0], "NORM" : !pto.mask<b16>, !pto.ptr<ui8, ub>, index
    }
    return
  }
}

// CHECK-LABEL: define void @vmadd_f32_store_mix_aiv
// CHECK: call <64 x float> @llvm.hivm.vmadd.m.v64f32
// CHECK-LABEL: define void @vcbmax_vcbmin_i16_store_mix_aiv
// CHECK: call { <128 x i16>, <256 x i1> } @llvm.hivm.vcbmax.s.x.v128i16
// CHECK: call { <128 x i16>, <256 x i1> } @llvm.hivm.vcbmin.s.x.v128i16
