// RUN: not ptoas --pto-arch=a5 %s -o - 2>&1 | FileCheck %s

module attributes {"pto.target_arch" = "a5"} {
  func.func @acc_store_verify_invalid_clip_payload_ui8(%src: !pto.ptr<f32, l0c>,
                                                       %dst: !pto.ptr<ui8, ub>) {
    %c0_i64 = arith.constant 0 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64
    %c7_i8 = arith.constant 7 : i8

    pto.mte_l0c_ub %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64, dst_mode(%c0_i64),
      pre_relu(mode = no_relu, clip = %c7_i8)
      : !pto.ptr<f32, l0c>, !pto.ptr<ui8, ub>, i64, i64, i64, i64, i64,
        i8

    return
  }
}

// CHECK: clip for ui8 destination requires ui16/signless i16 payload
