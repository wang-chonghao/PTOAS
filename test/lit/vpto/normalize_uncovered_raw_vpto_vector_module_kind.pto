// Guard: uncovered section normalization must infer pto.kernel_kind<vector>
// for child modules that already contain raw VPTO vector micro-ops instead of
// tile ops or explicit pto.section.vector wrappers.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "vpto", pto.target_arch = "a5"} {
    func.func public @raw_vec_kernel(%src: !pto.ptr<f32, ub>, %dst: !pto.ptr<f32, ub>) {
      %c0 = arith.constant 0 : index
      %mask = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      %vec0 = pto.vlds %src[%c0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
      %vec1 = pto.vlds %dst[%c0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
      %sum = pto.vadd %vec0, %vec1, %mask : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>
      pto.vsts %sum, %dst[%c0], %mask {dist = "NORM_B32"} : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
      return
    }
  }
}

// CHECK: module attributes {pto.backend = "vpto", pto.target_arch = "a5"} {
// CHECK: module attributes {pto.backend = "vpto", pto.kernel_kind = #pto.kernel_kind<vector>, pto.target_arch = "a5"} {
// CHECK-LABEL: func.func public @raw_vec_kernel
// CHECK: pto.vlds
// CHECK: pto.vadd
// CHECK: pto.vsts
