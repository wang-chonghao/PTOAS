// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @pltm_store(%dst: !pto.ptr<ui8, ub>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %loop = arith.constant 2 : i16
    %bound = arith.constant 192 : i32
    pto.vecscope {
      %m8 = pto.pltm_b8 %loop, %bound : i16, i32 -> !pto.mask<b8>
      %m16 = pto.pltm_b16 %loop, %bound : i16, i32 -> !pto.mask<b16>
      %m32 = pto.pltm_b32 %loop, %bound : i16, i32 -> !pto.mask<b32>
      pto.psts %m8, %dst[%c0], "NORM" : !pto.mask<b8>, !pto.ptr<ui8, ub>, index
      pto.psts %m16, %dst[%c0], "NORM" : !pto.mask<b16>, !pto.ptr<ui8, ub>, index
      pto.psts %m32, %dst[%c0], "NORM" : !pto.mask<b32>, !pto.ptr<ui8, ub>, index
    }
    return
  }
}

// CHECK-LABEL: llvm.func @pltm_store_mix_aiv
// CHECK: llvm.call @llvm.hivm.pltm.b8.v300
// CHECK: llvm.call @llvm.hivm.pltm.b16.v300
// CHECK: llvm.call @llvm.hivm.pltm.b32.v300
