// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - | FileCheck %s

module attributes {
  pto.backend = "emitc",
  pto.kernel_kind = #pto.kernel_kind<vector>,
  pto.target_arch = "a5"
} {
  func.func @backend_cli_override_to_vpto() {
    %ctrl = pto.get_ctrl : i64
    pto.set_ctrl %ctrl : i64
    return
  }
}

// CHECK: pto.get_ctrl
// CHECK: pto.set_ctrl
