// RUN: not env -u ASCEND_HOME_PATH ptoas --pto-arch=a5 %s -o %t.o 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "emitc"} {
    func.func private @vpto_post(%arg0: i64)

    func.func @emitc_entry() attributes {pto.aicore} {
      %c0 = arith.constant 0 : i64
      func.call @vpto_post(%c0) : (i64) -> ()
      return
    }
  }

  module attributes {
    pto.backend = "vpto",
    pto.kernel_kind = #pto.kernel_kind<vector>
  } {
    func.func public @vpto_post(%arg0: i64) {
      return
    }
    func.func @vpto_device() attributes {pto.aicore} {
      return
    }
  }
}

// CHECK: ASCEND_HOME_PATH is required
