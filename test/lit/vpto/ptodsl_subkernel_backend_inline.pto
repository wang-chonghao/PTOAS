// Guards shared backend-helper inlining for PTODSL subkernel helpers on the
// normal VPTO path. This pass runs before VPTO tile-op expansion, so the tile
// op itself should remain as pto.tadd here.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-after=pto-inline-backend-helpers %s -o /dev/null 2>&1 | FileCheck %s

module attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @kernel(%arg0: i32) {
    %tile_a = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile_b = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile_out = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tadd ins(%tile_a, %tile_b : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                                   blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                               !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                                   blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             outs(%tile_out : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                                     blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    %0 = func.call @ptodsl_simd_helper(%arg0) : (i32) -> i32
    %1 = func.call @regular_passthrough(%0) : (i32) -> i32
    return
  }

  func.func private @ptodsl_simd_helper(%x: i32) -> i32 attributes {pto.ptodsl.subkernel_helper = "simd"} {
    %c1 = arith.constant 1 : i32
    %y = arith.addi %x, %c1 : i32
    return %y : i32
  }

  func.func private @regular_passthrough(%x: i32) -> i32 {
    return %x : i32
  }
}

// CHECK-LABEL: func.func @kernel
// CHECK: pto.tadd
// CHECK: arith.constant 1 : i32
// CHECK: arith.addi %arg0, %{{[^,]+}} : i32
// CHECK-NOT: func.call @ptodsl_simd_helper
// CHECK: call @regular_passthrough
// CHECK-NOT: func.func private @ptodsl_simd_helper
// CHECK: func.func private @regular_passthrough
