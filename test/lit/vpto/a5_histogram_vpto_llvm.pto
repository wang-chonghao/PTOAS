// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @histv2_store(%acc: !pto.vreg<128xui16>, %src: !pto.vreg<256xui8>, %dst: !pto.ptr<ui16, ub>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %bin = arith.constant 16 : i32
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %store_mask = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
      %chist = pto.chistv2 %acc, %src, %mask, %bin : !pto.vreg<128xui16>, !pto.vreg<256xui8>, !pto.mask<b8>, i32 -> !pto.vreg<128xui16>
      %dhist = pto.dhistv2 %chist, %src, %mask, %bin : !pto.vreg<128xui16>, !pto.vreg<256xui8>, !pto.mask<b8>, i32 -> !pto.vreg<128xui16>
      pto.vsts %dhist, %dst[%c0], %store_mask : !pto.vreg<128xui16>, !pto.ptr<ui16, ub>, !pto.mask<b16>
    }
    return
  }
}

// CHECK-LABEL: llvm.func @histv2_store_mix_aiv
// CHECK: llvm.call @llvm.hivm.chistv2.m
// CHECK: llvm.call @llvm.hivm.dhistv2.m
