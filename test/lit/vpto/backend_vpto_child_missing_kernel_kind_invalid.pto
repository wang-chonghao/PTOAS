// RUN: not ptoas --pto-arch=a5 --emit-vpto %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "vpto"} {
    func.func @missing_kernel_kind() {
      return
    }
  }
}

// CHECK: expected VPTO kernel submodule to carry 'pto.kernel_kind'
