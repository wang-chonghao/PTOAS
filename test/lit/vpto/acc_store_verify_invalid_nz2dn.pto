// RUN: not ptoas --pto-arch=a5 %s -o - 2>&1 | FileCheck %s

module attributes {"pto.target_arch" = "a5"} {
  func.func @acc_store_verify_invalid_nz2dn(%src: !pto.ptr<f32, l0c>,
                                            %dst: !pto.ptr<f32, gm>) {
    %c0_i64 = arith.constant 0 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64

    pto.mte_l0c_gm %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64, %c0_i64, %c0_i64,
      nz2dn
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    return
  }
}

// CHECK: nz2dn requires loop0_src_stride
