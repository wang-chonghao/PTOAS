// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmulscvt_f32_to_f16_store(%src: !pto.ptr<f32, ub>, %dst: !pto.ptr<f16, ub>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %scale = arith.constant 1.000000e+00 : f32
    pto.vecscope {
      %src_mask = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      %dst_mask = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
      %vec = pto.vlds %src[%c0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
      %out = pto.vmulscvt %vec, %scale, %src_mask, "A", "EVEN" : !pto.vreg<64xf32>, f32, !pto.mask<b32> -> !pto.vreg<128xf16>
      pto.vsts %out, %dst[%c0], %dst_mask : !pto.vreg<128xf16>, !pto.ptr<f16, ub>, !pto.mask<b16>
    }
    return
  }
}

// CHECK-LABEL: llvm.func @vmulscvt_f32_to_f16_store_mix_aiv
// CHECK: llvm.call @llvm.hivm.vmulscvt.v128f16
// CHECK: llvm.call @llvm.hivm.vstsx1.v128f16
