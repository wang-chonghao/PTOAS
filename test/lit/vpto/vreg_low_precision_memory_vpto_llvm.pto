// RUN: ptoas --cann-output-version=9.0.0 --pto-arch=a5 --pto-backend=vpto --emit-vpto-llvm-ir %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @lowp_vlds_vsts(%f8e4_src: !pto.ptr<f8E4M3FN, ub>,
                            %f8e4_dst: !pto.ptr<f8E4M3FN, ub>,
                            %f8e5_src: !pto.ptr<f8E5M2, ub>,
                            %f8e5_dst: !pto.ptr<f8E5M2, ub>,
                            %hif8_src: !pto.ptr<!pto.hif8, ub>,
                            %hif8_dst: !pto.ptr<!pto.hif8, ub>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %f8e4 = pto.vlds %f8e4_src[%c0] : !pto.ptr<f8E4M3FN, ub> -> !pto.vreg<256xf8E4M3FN>
      %f8e5 = pto.vlds %f8e5_src[%c0] : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
      %hif8 = pto.vlds %hif8_src[%c0] : !pto.ptr<!pto.hif8, ub> -> !pto.vreg<256x!pto.hif8>
      pto.vsts %f8e4, %f8e4_dst[%c0], %mask : !pto.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>, !pto.mask<b8>
      pto.vsts %f8e5, %f8e5_dst[%c0], %mask : !pto.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>, !pto.mask<b8>
      pto.vsts %hif8, %hif8_dst[%c0], %mask : !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>, !pto.mask<b8>
    }
    return
  }

  func.func @lowp_x2_and_block(%f4e1_src: !pto.ptr<!pto.f4E1M2x2, ub>,
                               %f4e2_dst: !pto.ptr<!pto.f4E2M1x2, ub>,
                               %value: !pto.vreg<256x!pto.f4E2M1x2>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1_i16 = arith.constant 1 : i16
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %low, %high = pto.vldsx2 %f4e1_src[%c0], "DINTLV_B8" : !pto.ptr<!pto.f4E1M2x2, ub>, index -> !pto.vreg<256x!pto.f4E1M2x2>, !pto.vreg<256x!pto.f4E1M2x2>
      pto.vstsx2 %low, %high, %f4e2_dst[%c0], "INTLV_B8", %mask : !pto.vreg<256x!pto.f4E1M2x2>, !pto.vreg<256x!pto.f4E1M2x2>, !pto.ptr<!pto.f4E2M1x2, ub>, index, !pto.mask<b8>
      %strided = pto.vsldb %f4e1_src, %c1_i16, %c1_i16, %mask : !pto.ptr<!pto.f4E1M2x2, ub>, i16, i16, !pto.mask<b8> -> !pto.vreg<256x!pto.f4E1M2x2>
      pto.vsstb %strided, %f4e2_dst, %c1_i16, %c1_i16, %mask : !pto.vreg<256x!pto.f4E1M2x2>, !pto.ptr<!pto.f4E2M1x2, ub>, i16, i16, !pto.mask<b8>
      pto.vsstb %value, %f4e2_dst, %c1_i16, %c1_i16, %mask : !pto.vreg<256x!pto.f4E2M1x2>, !pto.ptr<!pto.f4E2M1x2, ub>, i16, i16, !pto.mask<b8>
    }
    return
  }

  func.func @lowp_unaligned_state(%src: !pto.ptr<!pto.hif8, ub>,
                                  %dst: !pto.ptr<!pto.hif8, ub>,
                                  %value: !pto.vreg<256x!pto.hif8>) attributes {pto.kernel} {
    %c0_i32 = arith.constant 0 : i32
    pto.vecscope {
      %load_align = pto.vldas %src : !pto.ptr<!pto.hif8, ub> -> !pto.align
      %loaded, %align1 = pto.vldus %src, %load_align : !pto.ptr<!pto.hif8, ub>, !pto.align -> !pto.vreg<256x!pto.hif8>, !pto.align
      %store_align = pto.init_align : !pto.align
      %align2 = pto.vstus %store_align, %c0_i32, %loaded, %dst : !pto.align, i32, !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub> -> !pto.align
      %align3 = pto.vstur %align2, %value, %dst, "POST_UPDATE" : !pto.align, !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub> -> !pto.align
      pto.vstar %align3, %dst : !pto.align, !pto.ptr<!pto.hif8, ub>
    }
    return
  }

  func.func @lowp_uvld_expansion(%src: !pto.ptr<f8E4M3FN, ub>,
                                 %dst: !pto.ptr<f8E4M3FN, ub>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %u = pto.uvld %src[%c0] : !pto.ptr<f8E4M3FN, ub> -> !pto.vreg<256xf8E4M3FN>
      pto.vsts %u, %dst[%c0], %mask : !pto.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>, !pto.mask<b8>
    }
    return
  }
}

// CHECK-LABEL: define void @lowp_vlds_vsts_mix_aiv
// CHECK: call <256 x i8> @llvm.hivm.vldsx1.v256f8e4m3
// CHECK: call <256 x i8> @llvm.hivm.vldsx1.v256f8e5m2
// CHECK: call <256 x i8> @llvm.hivm.vldsx1.v256s8
// CHECK: call void @llvm.hivm.vstsx1.v256f8e4m3
// CHECK: call void @llvm.hivm.vstsx1.v256f8e5m2
// CHECK: call void @llvm.hivm.vstsx1.v256s8

// CHECK-LABEL: define void @lowp_x2_and_block_mix_aiv
// CHECK: call { <256 x i8>, <256 x i8> } @llvm.hivm.vldsx2.v256f4e1m2x2
// CHECK: call void @llvm.hivm.vstsx2.v256f4e1m2x2
// CHECK: call <256 x i8> @llvm.hivm.vsldb
// CHECK: call void @llvm.hivm.vsstb
// CHECK: call void @llvm.hivm.vsstb

// CHECK-LABEL: define void @lowp_unaligned_state_mix_aiv
// CHECK: call <32 x i8> @llvm.hivm.vldas
// CHECK: call { <256 x i8>, <32 x i8>, ptr addrspace(6) } @llvm.hivm.vldus.v256s8
// CHECK: call <32 x i8> @llvm.hivm.vstus
// CHECK: call <32 x i8> @llvm.hivm.vstur
// CHECK: call void @llvm.hivm.vstar

// CHECK-LABEL: define void @lowp_uvld_expansion_mix_aiv
// CHECK: call <32 x i8> @llvm.hivm.vldas
// CHECK: call { <256 x i8>, <32 x i8>, ptr addrspace(6) } @llvm.hivm.vldus.v256f8e4m3
// CHECK: call void @llvm.hivm.vstsx1.v256f8e4m3
