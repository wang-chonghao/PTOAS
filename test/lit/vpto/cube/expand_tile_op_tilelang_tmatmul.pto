// Guard: TileLang cube tmatmul expansion on the dav-c310-cube VPTO path must
// inline the template body and lower the tile op to cube MAD instructions.
//
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --enable-tile-op-expand --emit-vpto %s -o - 2>/dev/null | FileCheck %s

// CHECK-LABEL: func.func @TMATMUL
// CHECK-NOT: pto.tmatmul ins
// CHECK: pto.mad

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @TMATMUL() attributes {pto.kernel} {
    %lhs = pto.alloc_tile
      : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                      blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %rhs = pto.alloc_tile
      : !pto.tile_buf<loc=right, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                      blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %acc = pto.alloc_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16,
                      blayout=col_major, slayout=row_major, fractal=1024, pad=0>

    pto.tmatmul ins(%lhs, %rhs : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                                    blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                                !pto.tile_buf<loc=right, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                                    blayout=row_major, slayout=col_major, fractal=512, pad=0>)
                outs(%acc : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16,
                                          blayout=col_major, slayout=row_major, fractal=1024, pad=0>)
    return
  }
}
