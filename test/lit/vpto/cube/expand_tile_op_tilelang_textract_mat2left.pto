// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --enable-tile-op-expand --emit-vpto %s -o - 2>/dev/null | FileCheck %s



// CHECK-LABEL: func.func @TEXTRACT_M2L

// CHECK-NOT: pto.textract ins

// CHECK: pto.load_cbuf_to_ca



module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {

  func.func @TEXTRACT_M2L() attributes {pto.aicore} {

    %c0 = arith.constant 0 : index

    %src = pto.alloc_tile

      : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32,

                      blayout=row_major, slayout=col_major, fractal=512, pad=0>

    %dst = pto.alloc_tile

      : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,

                      blayout=col_major, slayout=row_major, fractal=512, pad=0>



    pto.textract ins(%src, %c0, %c0 : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32,

                                     blayout=row_major, slayout=col_major, fractal=512, pad=0>, index, index)

                outs(%dst : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,

                                           blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    return

  }

}
