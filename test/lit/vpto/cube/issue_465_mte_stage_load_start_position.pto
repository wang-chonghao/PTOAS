// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-before=vpto-expand-wrapper-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=ROUNDTRIP
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-after=vpto-expand-wrapper-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=EXPAND

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @issue_465_mte_stage_load_start_position(
      %src_mat: memref<?xf16, #pto.address_space<mat>>,
      %dst_left: memref<?xf16, #pto.address_space<left>>,
      %dst_right: memref<?xf16, #pto.address_space<right>>) attributes {pto.kernel} {
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64
    %c2_i64 = arith.constant 2 : i64
    %c3_i64 = arith.constant 3 : i64
    %c4_i64 = arith.constant 4 : i64
    %c5_i64 = arith.constant 5 : i64

    pto.mte_l1_l0a %src_mat, %dst_left, %c16_i64, %c32_i64, %c2_i64, %c3_i64
      : memref<?xf16, #pto.address_space<mat>>, memref<?xf16, #pto.address_space<left>>, i64, i64, i64, i64
    pto.mte_l1_l0b %src_mat, %dst_right, %c32_i64, %c16_i64, %c4_i64, %c5_i64 {transpose = true}
      : memref<?xf16, #pto.address_space<mat>>, memref<?xf16, #pto.address_space<right>>, i64, i64, i64, i64

    return
  }
}

// ROUNDTRIP-LABEL: func.func @issue_465_mte_stage_load_start_position(
// ROUNDTRIP: pto.mte_l1_l0a %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}
// ROUNDTRIP: pto.mte_l1_l0b %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}} {transpose = true}

// EXPAND-LABEL: func.func @issue_465_mte_stage_load_start_position(
// EXPAND-DAG: %[[LHS_ROW:.*]] = arith.constant 2 : i64
// EXPAND-DAG: %[[LHS_COL:.*]] = arith.constant 3 : i64
// EXPAND-DAG: %[[RHS_ROW:.*]] = arith.constant 4 : i64
// EXPAND-DAG: %[[RHS_COL:.*]] = arith.constant 5 : i64
// EXPAND: pto.load_cbuf_to_ca %{{.*}}, %{{.*}}, %[[LHS_ROW]], %[[LHS_COL]]
// EXPAND: pto.load_cbuf_to_cb %{{.*}}, %{{.*}}, %[[RHS_ROW]], %[[RHS_COL]]
