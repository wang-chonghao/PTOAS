// RUN: not ptoas --pto-arch=a5 %s -o - 2>&1 | FileCheck %s

module attributes {"pto.target_arch" = "a5"} {
  func.func @acc_store_verify_invalid_atomic(%src: !pto.ptr<f32, l0c>,
                                             %dst: !pto.ptr<f32, l1>) {
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64

    pto.mte_l0c_l1 %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64,
      atomic(type = f32, op = add)
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, l1>, i64, i64, i64, i64

    return
  }
}

// CHECK: atomic is only supported for mte_l0c_gm
