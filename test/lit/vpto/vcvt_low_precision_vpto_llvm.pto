// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vcvt_low_precision(%f32_seed: f32, %bf16_seed: bf16,
                                %dst_f32: !pto.ptr<f32, ub>,
                                %dst_bf16: !pto.ptr<bf16, ub>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c64 = arith.constant 64 : index
    %c128 = arith.constant 128 : index
    pto.vecscope {
      %mask_b8 = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %mask_b16 = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
      %mask_b32 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>

      %src_f32 = pto.vdup %f32_seed, %mask_b32 : f32, !pto.mask<b32> -> !pto.vreg<64xf32>
      %f8e4 = pto.vcvt %src_f32, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P0"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E4M3FN>
      %back_f32 = pto.vcvt %f8e4, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E4M3FN>, !pto.mask<b8> -> !pto.vreg<64xf32>
      pto.vsts %back_f32, %dst_f32[%c0], %mask_b32 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>

      %f8e5 = pto.vcvt %src_f32, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P0"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E5M2>
      %back_f32_e5 = pto.vcvt %f8e5, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
      pto.vsts %back_f32_e5, %dst_f32[%c64], %mask_b32 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>

      %hif8 = pto.vcvt %src_f32, %mask_b32 {rnd = "A", sat = "NOSAT", part = "P0"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
      %back_f32_hif8 = pto.vcvt %hif8, %mask_b8 {part = "P0"} : !pto.vreg<256x!pto.hif8>, !pto.mask<b8> -> !pto.vreg<64xf32>
      pto.vsts %back_f32_hif8, %dst_f32[%c128], %mask_b32 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>

      %src_bf16 = pto.vdup %bf16_seed, %mask_b16 : bf16, !pto.mask<b16> -> !pto.vreg<128xbf16>
      %f4e1 = pto.vcvt %src_bf16, %mask_b16 {rnd = "R", part = "P0"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256x!pto.f4E1M2x2>
      %back_bf16 = pto.vcvt %f4e1, %mask_b8 {part = "P0"} : !pto.vreg<256x!pto.f4E1M2x2>, !pto.mask<b8> -> !pto.vreg<128xbf16>
      pto.vsts %back_bf16, %dst_bf16[%c0], %mask_b16 : !pto.vreg<128xbf16>, !pto.ptr<bf16, ub>, !pto.mask<b16>

      %f4e2 = pto.vcvt %src_bf16, %mask_b16 {rnd = "R", part = "P0"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256x!pto.f4E2M1x2>
      %back_bf16_e2 = pto.vcvt %f4e2, %mask_b8 {part = "P0"} : !pto.vreg<256x!pto.f4E2M1x2>, !pto.mask<b8> -> !pto.vreg<128xbf16>
      pto.vsts %back_bf16_e2, %dst_bf16[%c128], %mask_b16 : !pto.vreg<128xbf16>, !pto.ptr<bf16, ub>, !pto.mask<b16>
    }
    return
  }
}

// CHECK-LABEL: llvm.func @vcvt_low_precision_mix_aiv
// CHECK: llvm.call @llvm.hivm.vcvtff.f322f8e4m3.x
// CHECK: llvm.call @llvm.hivm.vcvtff.f8e4m32f32.x
// CHECK: llvm.call @llvm.hivm.vcvtff.f322f8e5m2.x
// CHECK: llvm.call @llvm.hivm.vcvtff.f8e5m22f32.x
// CHECK: llvm.call @llvm.hivm.vcvtff.f322hif8.x
// CHECK: llvm.call @llvm.hivm.vcvtff.hif82f32.x
// CHECK: llvm.call @llvm.hivm.vcvtff2.bf162f4e1m2x2.x
// CHECK: llvm.call @llvm.hivm.vcvtff2.f4e1m2x22bf16.x
// CHECK: llvm.call @llvm.hivm.vcvtff2.bf162f4e2m1x2.x
// CHECK: llvm.call @llvm.hivm.vcvtff2.f4e2m1x22bf16.x
