// Guard: uncovered VPTO vector kernels without an explicit section wrapper must
// still normalize into a nested VPTO child module with inferred vector
// kernel_kind, while the outer module keeps the backend-only shell form.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @vector_kernel(%dst: !pto.ptr<f32, ub>) {
    %c0 = arith.constant 0 : index
    %mask = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
    %src = pto.vlds %dst[%c0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
    pto.vsts %src, %dst[%c0], %mask : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
    return
  }
}

// CHECK-LABEL: module attributes {pto.backend = "vpto", pto.target_arch = "a5"} {
// CHECK: module attributes {pto.backend = "vpto", pto.kernel_kind = #pto.kernel_kind<vector>, pto.target_arch = "a5"} {
// CHECK-LABEL: func.func @vector_kernel
// CHECK-NOT: pto.section.vector
