// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @spr_store(%dst: !pto.ptr<ui32, ub>, %dyn_offset: i32) attributes {pto.kernel} {
    %c4 = arith.constant 4 : i32
    pto.vecscope {
      pto.sprclr "AR"
      pto.sprsti "AR", %dst[%c4] : !pto.ptr<ui32, ub>, i32
      pto.sprsts "AR", %dst[%dyn_offset] : !pto.ptr<ui32, ub>, i32
    }
    return
  }
}

// CHECK-LABEL: llvm.func @spr_store_mix_aiv
// CHECK: llvm.call @llvm.hivm.sprclr
// CHECK: llvm.call @llvm.hivm.sprsti
// CHECK: llvm.call @llvm.hivm.sprsts
