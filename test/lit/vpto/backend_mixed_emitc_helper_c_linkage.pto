// RUN: ptoas --cann-output-version=9.0.0 --pto-arch=a5 --emit-pto-ir %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "emitc"} {
    func.func private @helper()

    func.func @entry() attributes {pto.aicore} {
      func.call @helper() : () -> ()
      return
    }
  }

  module attributes {
    pto.backend = "emitc",
    pto.kernel_kind = #pto.kernel_kind<vector>
  } {
    func.func public @helper() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
      return
    }
  }
}

// CHECK-LABEL: module attributes {pto.backend = "emitc", pto.target_arch = "a5"} {
// CHECK: module attributes {pto.backend = "emitc"} {
// CHECK: func.func private @helper()
// CHECK: func.func @entry() attributes {pto.aicore} {
// CHECK: call @helper() : () -> ()
// CHECK: return
// CHECK: module attributes {pto.backend = "emitc", pto.kernel_kind = #pto.kernel_kind<vector>} {
// CHECK: func.func public @helper() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
// CHECK-NEXT: return
// CHECK-NEXT: }
