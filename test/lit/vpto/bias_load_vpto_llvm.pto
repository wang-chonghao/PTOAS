// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @bias_load_f16_to_f32() attributes {pto.kernel} {
    %c0 = arith.constant 0 : i64
    %c2 = arith.constant 2 : i64
    %c4 = arith.constant 4 : i64
    %src = pto.castptr %c0 : i64 -> !pto.ptr<f16, l1>
    %dst = pto.castptr %c0 : i64 -> !pto.ptr<f32, bt>

    pto.mte_l1_bt %src, %dst, %c4 nburst(%c2, %c0, %c0)
      : !pto.ptr<f16, l1>, !pto.ptr<f32, bt>, i64, i64, i64, i64
    return
  }
}

// CHECK-LABEL: llvm.func @bias_load_f16_to_f32_mix_aic
// CHECK: llvm.call @llvm.hivm.MOV.L1.TO.BT.f16
