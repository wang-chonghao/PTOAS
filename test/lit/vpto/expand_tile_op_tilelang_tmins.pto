// Test that pto.tmins can be lowered to vector-style VPTO IR.
//
// IMPORTANT: Do NOT use --enable-tile-op-expand for ops with scalar operands.
// TMINS has a scalar operand (f32), so it uses the PTOToVPTO lowering path.
//
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - 2>/dev/null | FileCheck %s

// After PTOToVPTO lowering, pto.tmins should use vmins (vector min scalar).
// CHECK: func.func @TMINS
// CHECK-NOT: pto.tmins ins
// CHECK: pto.vecscope
// CHECK: pto.vlds
// CHECK: pto.vmins
// CHECK: pto.vsts

module attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @TMINS() {
    %a = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile_buf = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %scalar = arith.constant 0.0 : f32

    pto.tmins ins(%a, %scalar : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                              blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                                f32)
              outs(%tile_buf : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                                    blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}
