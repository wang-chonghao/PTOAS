module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @matmulmx_highlevel(%arg0: !pto.ptr<f8E4M3FN, gm>, %arg1: !pto.ptr<f8E5M2, gm>, %arg2: !pto.ptr<!pto.f8E8M0, gm>, %arg3: !pto.ptr<!pto.f8E8M0, gm>, %arg4: !pto.ptr<f32, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c63 = arith.constant 63 : index
    %c64 = arith.constant 64 : index
    %c110 = arith.constant 110 : index
    %c128 = arith.constant 128 : index
    %c4 = arith.constant 4 : index
    %c1 = arith.constant 1 : index
    %0 = pto.make_tensor_view %arg0, shape = [%c128, %c110], strides = [%c110, %c1] : !pto.tensor_view<?x?xf8E4M3FN>
