    %c1_2 = arith.constant 1 : index
    %3 = pto.make_tensor_view %arg3, shape = [%c4, %c63], strides = [%c63, %c1_2] : !pto.tensor_view<?x?x!pto.f8E8M0>
    %c1_3 = arith.constant 1 : index
