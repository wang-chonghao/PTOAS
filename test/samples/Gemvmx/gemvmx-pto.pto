module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @gemvmx_kernel(%arg0: !pto.ptr<f8E4M3FN, gm>, %arg1: !pto.ptr<f8E5M2, gm>, %arg2: !pto.ptr<!pto.f8E8M0, gm>, %arg3: !pto.ptr<!pto.f8E8M0, gm>, %arg4: !pto.ptr<f32, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c4 = arith.constant 4 : index
    %c16 = arith.constant 16 : index
    %c128 = arith.constant 128 : index

    %0 = pto.make_tensor_view %arg0, shape = [%c1, %c128], strides = [%c128, %c1] : !pto.tensor_view<?x?xf8E4M3FN>
    %1 = pto.make_tensor_view %arg1, shape = [%c128, %c16], strides = [%c16, %c1] : !pto.tensor_view<?x?xf8E5M2>
    %2 = pto.make_tensor_view %arg2, shape = [%c1, %c4], strides = [%c4, %c1] : !pto.tensor_view<?x?x!pto.f8E8M0>
    %3 = pto.make_tensor_view %arg3, shape = [%c4, %c16], strides = [%c16, %c1] : !pto.tensor_view<?x?x!pto.f8E8M0>
    %4 = pto.make_tensor_view %arg4, shape = [%c1, %c16], strides = [%c16, %c1] : !pto.tensor_view<?x?xf32>

    %5 = pto.partition_view %0, offsets = [%c0, %c0], sizes = [%c1, %c128] : !pto.tensor_view<?x?xf8E4M3FN>
    %6 = pto.partition_view %1, offsets = [%c0, %c0], sizes = [%c128, %c16] : !pto.tensor_view<?x?xf8E5M2>
    %7 = pto.partition_view %2, offsets = [%c0, %c0], sizes = [%c1, %c4] : !pto.tensor_view<?x?x!pto.f8E8M0>
    %8 = pto.partition_view %3, offsets = [%c0, %c0], sizes = [%c4, %c16] : !pto.tensor_view<?x?x!pto.f8E8M0>

    %9 = pto.alloc_tile : !pto.tile_buf<mat, 1x512xf8E4M3FN, valid=1x128>
    %10 = pto.alloc_tile : !pto.tile_buf<mat, 128x32xf8E5M2, valid=128x16, blayout=col_major, slayout=row_major, pad=1>
    %11 = pto.alloc_tile : !pto.tile_buf<mat, 1x4x!pto.f8E8M0, slayout=row_major, fractal=32>
    %12 = pto.alloc_tile : !pto.tile_buf<mat, 4x32x!pto.f8E8M0, valid=4x16, blayout=col_major, slayout=col_major, fractal=32>

    %13 = pto.alloc_tile : !pto.tile_buf<left, 1x512xf8E4M3FN, valid=1x128, blayout=col_major, slayout=row_major>
    %14 = pto.alloc_tile : !pto.tile_buf<right, 128x32xf8E5M2, valid=128x16, slayout=col_major>
    %15 = pto.alloc_tile : !pto.tile_buf<scaling, 1x4x!pto.f8E8M0, slayout=row_major, fractal=32>
    %16 = pto.alloc_tile : !pto.tile_buf<scaling, 4x32x!pto.f8E8M0, valid=4x16, blayout=col_major, slayout=col_major, fractal=32>
    %17 = pto.alloc_tile : !pto.tile_buf<acc, 1x32xf32, valid=1x16, blayout=col_major, slayout=row_major, fractal=1024>

    pto.tload ins(%5 : !pto.partition_tensor_view<1x128xf8E4M3FN>) outs(%9 : !pto.tile_buf<mat, 1x512xf8E4M3FN, valid=1x128>)
    pto.tload ins(%6 : !pto.partition_tensor_view<128x16xf8E5M2>) outs(%10 : !pto.tile_buf<mat, 128x32xf8E5M2, valid=128x16, blayout=col_major, slayout=row_major, pad=1>)
    pto.tfillpad ins(%10 : !pto.tile_buf<mat, 128x32xf8E5M2, valid=128x16, blayout=col_major, slayout=row_major, pad=1>)
                 outs(%10 : !pto.tile_buf<mat, 128x32xf8E5M2, valid=128x16, blayout=col_major, slayout=row_major, pad=1>)
    pto.tload ins(%7 : !pto.partition_tensor_view<1x4x!pto.f8E8M0>) outs(%11 : !pto.tile_buf<mat, 1x4x!pto.f8E8M0, slayout=row_major, fractal=32>)
    pto.tload ins(%8 : !pto.partition_tensor_view<4x16x!pto.f8E8M0>) outs(%12 : !pto.tile_buf<mat, 4x32x!pto.f8E8M0, valid=4x16, blayout=col_major, slayout=col_major, fractal=32>)

    pto.textract ins(%9, %c0, %c0 : !pto.tile_buf<mat, 1x512xf8E4M3FN, valid=1x128>, index, index) outs(%13 : !pto.tile_buf<left, 1x512xf8E4M3FN, valid=1x128, blayout=col_major, slayout=row_major>)
    pto.textract ins(%10, %c0, %c0 : !pto.tile_buf<mat, 128x32xf8E5M2, valid=128x16, blayout=col_major, slayout=row_major, pad=1>, index, index) outs(%14 : !pto.tile_buf<right, 128x32xf8E5M2, valid=128x16, slayout=col_major>)
    pto.tmov ins(%11 : !pto.tile_buf<mat, 1x4x!pto.f8E8M0, slayout=row_major, fractal=32>) outs(%15 : !pto.tile_buf<scaling, 1x4x!pto.f8E8M0, slayout=row_major, fractal=32>)
    pto.tmov ins(%12 : !pto.tile_buf<mat, 4x32x!pto.f8E8M0, valid=4x16, blayout=col_major, slayout=col_major, fractal=32>) outs(%16 : !pto.tile_buf<scaling, 4x32x!pto.f8E8M0, valid=4x16, blayout=col_major, slayout=col_major, fractal=32>)

    pto.tget_scale_addr ins(%13 : !pto.tile_buf<left, 1x512xf8E4M3FN, valid=1x128, blayout=col_major, slayout=row_major>) outs(%15 : !pto.tile_buf<scaling, 1x4x!pto.f8E8M0, slayout=row_major, fractal=32>)
    pto.tget_scale_addr ins(%14 : !pto.tile_buf<right, 128x32xf8E5M2, valid=128x16, slayout=col_major>) outs(%16 : !pto.tile_buf<scaling, 4x32x!pto.f8E8M0, valid=4x16, blayout=col_major, slayout=col_major, fractal=32>)

    pto.tgemv.mx ins(%13, %15, %14, %16 : !pto.tile_buf<left, 1x512xf8E4M3FN, valid=1x128, blayout=col_major, slayout=row_major>, !pto.tile_buf<scaling, 1x4x!pto.f8E8M0, slayout=row_major, fractal=32>, !pto.tile_buf<right, 128x32xf8E5M2, valid=128x16, slayout=col_major>, !pto.tile_buf<scaling, 4x32x!pto.f8E8M0, valid=4x16, blayout=col_major, slayout=col_major, fractal=32>) outs(%17 : !pto.tile_buf<acc, 1x32xf32, valid=1x16, blayout=col_major, slayout=row_major, fractal=1024>)

    %18 = pto.partition_view %4, offsets = [%c0, %c0], sizes = [%c1, %c16] : !pto.tensor_view<?x?xf32>
    pto.tstore ins(%17 : !pto.tile_buf<acc, 1x32xf32, valid=1x16, blayout=col_major, slayout=row_major, fractal=1024>) outs(%18 : !pto.partition_tensor_view<1x16xf32>)
    return
  }
}
