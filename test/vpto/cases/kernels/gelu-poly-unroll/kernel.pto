module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @fusion_loop_unroll_gelu_poly_vfsim(
      %x_ptr: !pto.ptr<f32>, %out_ptr: !pto.ptr<f32>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c16 = arith.constant 16 : index
    %c64 = arith.constant 64 : index
    %c1024 = arith.constant 1024 : index
    %c_neg4 = arith.constant -4.000000e+00 : f32
    %c_pos4 = arith.constant 4.000000e+00 : f32
    %c05 = arith.constant 5.000000e-01 : f32
    %c03989 = arith.constant 3.989000e-01 : f32
    %c00447 = arith.constant 4.470000e-02 : f32

    %x_view = pto.make_tensor_view %x_ptr,
      shape = [%c1, %c1, %c1, %c16, %c64],
      strides = [%c1024, %c1024, %c1024, %c64, %c1]
      : !pto.tensor_view<1x1x1x16x64xf32>
    %out_view = pto.make_tensor_view %out_ptr,
      shape = [%c1, %c1, %c1, %c16, %c64],
      strides = [%c1024, %c1024, %c1024, %c64, %c1]
      : !pto.tensor_view<1x1x1x16x64xf32>

    %x_part = pto.partition_view %x_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c16, %c64]
      : !pto.tensor_view<1x1x1x16x64xf32> -> !pto.partition_tensor_view<1x1x1x16x64xf32>
    %out_part = pto.partition_view %out_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c16, %c64]
      : !pto.tensor_view<1x1x1x16x64xf32> -> !pto.partition_tensor_view<1x1x1x16x64xf32>

    %x = pto.alloc_tile : !pto.tile_buf<vec, 16x64xf32>
    %x_clamp = pto.alloc_tile : !pto.tile_buf<vec, 16x64xf32>
    %x2 = pto.alloc_tile : !pto.tile_buf<vec, 16x64xf32>
    %x3 = pto.alloc_tile : !pto.tile_buf<vec, 16x64xf32>
    %poly = pto.alloc_tile : !pto.tile_buf<vec, 16x64xf32>
    %gate = pto.alloc_tile : !pto.tile_buf<vec, 16x64xf32>
    %out = pto.alloc_tile : !pto.tile_buf<vec, 16x64xf32>

    pto.tload ins(%x_part : !pto.partition_tensor_view<1x1x1x16x64xf32>)
              outs(%x : !pto.tile_buf<vec, 16x64xf32>)
    pto.tmaxs ins(%x, %c_neg4 : !pto.tile_buf<vec, 16x64xf32>, f32)
              outs(%x_clamp : !pto.tile_buf<vec, 16x64xf32>)
    pto.tmins ins(%x_clamp, %c_pos4 : !pto.tile_buf<vec, 16x64xf32>, f32)
              outs(%x_clamp : !pto.tile_buf<vec, 16x64xf32>)
    pto.tmul ins(%x_clamp, %x_clamp : !pto.tile_buf<vec, 16x64xf32>, !pto.tile_buf<vec, 16x64xf32>)
             outs(%x2 : !pto.tile_buf<vec, 16x64xf32>)
    pto.tmul ins(%x2, %x_clamp : !pto.tile_buf<vec, 16x64xf32>, !pto.tile_buf<vec, 16x64xf32>)
             outs(%x3 : !pto.tile_buf<vec, 16x64xf32>)
    pto.tmuls ins(%x3, %c00447 : !pto.tile_buf<vec, 16x64xf32>, f32)
              outs(%poly : !pto.tile_buf<vec, 16x64xf32>)
    pto.tadds ins(%poly, %c03989 : !pto.tile_buf<vec, 16x64xf32>, f32)
              outs(%poly : !pto.tile_buf<vec, 16x64xf32>)
    pto.tmul ins(%poly, %x_clamp : !pto.tile_buf<vec, 16x64xf32>, !pto.tile_buf<vec, 16x64xf32>)
             outs(%gate : !pto.tile_buf<vec, 16x64xf32>)
    pto.tadds ins(%gate, %c05 : !pto.tile_buf<vec, 16x64xf32>, f32)
              outs(%gate : !pto.tile_buf<vec, 16x64xf32>)
    pto.tmul ins(%x_clamp, %gate : !pto.tile_buf<vec, 16x64xf32>, !pto.tile_buf<vec, 16x64xf32>)
             outs(%out : !pto.tile_buf<vec, 16x64xf32>)

    pto.tstore ins(%out : !pto.tile_buf<vec, 16x64xf32>)
               outs(%out_part : !pto.partition_tensor_view<1x1x1x16x64xf32>)
    return
  }
}
