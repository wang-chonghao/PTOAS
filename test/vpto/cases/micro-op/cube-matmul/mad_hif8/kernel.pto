module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @mad_hif8_kernel(%a_gm: !pto.ptr<!pto.hif8, gm>,
                             %b_gm: !pto.ptr<!pto.hif8, gm>,
                             %c_hif8_gm: !pto.ptr<f32, gm>,
                             %a_fp8_gm: !pto.ptr<f8E4M3FN, gm>,
                             %b_fp8_gm: !pto.ptr<f8E4M3FN, gm>,
                             %c_fp8_gm: !pto.ptr<f32, gm>) attributes {pto.kernel} {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c64_i64 = arith.constant 64 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %false = arith.constant false

    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<!pto.hif8, l1>
    %l1_b = pto.castptr %c1024_i64 : i64 -> !pto.ptr<!pto.hif8, l1>
    %l0a = pto.castptr %c0_i64 : i64 -> !pto.ptr<!pto.hif8, l0a>
    %l0b = pto.castptr %c0_i64 : i64 -> !pto.ptr<!pto.hif8, l0b>
    %l0c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, l0c>
    %l0c_fp8 = pto.castptr %c4096_i64 : i64 -> !pto.ptr<f32, l0c>
    %l1_a_fp8 = pto.castptr %c0_i64 : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_fp8 = pto.castptr %c1024_i64 : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l0a_fp8 = pto.castptr %c0_i64 : i64 -> !pto.ptr<f8E4M3FN, l0a>
    %l0b_fp8 = pto.castptr %c0_i64 : i64 -> !pto.ptr<f8E4M3FN, l0b>

    pto.mte_gm_l1 %a_gm, %l1_a, %c1024_i64
      nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<!pto.hif8, gm>, !pto.ptr<!pto.hif8, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b, %c1024_i64
      nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<!pto.hif8, gm>, !pto.ptr<!pto.hif8, l1>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a, %l0a, %c16_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.hif8, l1>, !pto.ptr<!pto.hif8, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b, %l0b, %c64_i64, %c16_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<!pto.hif8, l1>, !pto.ptr<!pto.hif8, l0b>, i64, i64, i64, i64
    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.mad %l0a, %l0b, %l0c, %c16_i64, %c16_i64, %c64_i64
      : !pto.ptr<!pto.hif8, l0a>, !pto.ptr<!pto.hif8, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_hif8_gm, %c16_i64, %c16_i64, %c16_i64, %c16_i64,
      %c0_i64, %c0_i64,
      nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>

    pto.mte_gm_l1 %a_fp8_gm, %l1_a_fp8, %c1024_i64
      nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %b_fp8_gm, %l1_b_fp8, %c1024_i64
      nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]

    pto.mte_l1_l0a %l1_a_fp8, %l0a_fp8, %c16_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_fp8, %l0b_fp8, %c64_i64, %c16_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.mad %l0a_fp8, %l0b_fp8, %l0c_fp8, %c16_i64, %c16_i64, %c64_i64
      : !pto.ptr<f8E4M3FN, l0a>, !pto.ptr<f8E4M3FN, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID0"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID0"]

    pto.mte_l0c_gm %l0c_fp8, %c_fp8_gm, %c16_i64, %c16_i64, %c16_i64, %c16_i64,
      %c0_i64, %c0_i64,
      nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
