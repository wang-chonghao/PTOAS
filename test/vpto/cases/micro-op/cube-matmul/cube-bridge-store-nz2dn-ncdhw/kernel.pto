// -----------------------------------------------------------------------------
// case: vpto/cube-bridge-store-nz2dn-ncdhw
// family: vpto
// target_ops: pto.cube_load, pto.left_load, pto.right_load, pto.acc_store_gm
// scenarios: canonical nz2dn write-back configured as an NCDHW-style store
// -----------------------------------------------------------------------------
module attributes {pto.target_arch = "a5"} {
  func.func @cube_bridge_store_nz2dn_ncdhw_kernel(%a_gm: !pto.ptr<f16, gm>,
                                                  %b_gm: !pto.ptr<f16, gm>,
                                                  %c_gm: !pto.ptr<f32, gm>) {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c48_i64 = arith.constant 48 : i64

    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, mat>
    %l1_b = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, mat>
    %l0a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, left>
    %l0b = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, right>
    %l0c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, acc>

    pto.cube_load %a_gm, %l1_a, %c16_i64
      nburst(%c1_i64, %c0_i64, %c0_i64)
      loop(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, mat>, i64, i64, i64, i64, loop i64, i64, i64
    pto.cube_load %b_gm, %l1_b, %c16_i64
      nburst(%c1_i64, %c0_i64, %c0_i64)
      loop(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, mat>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.left_load %l1_a, %l0a, %c16_i64, %c16_i64
      : !pto.ptr<f16, mat>, !pto.ptr<f16, left>, i64, i64
    pto.right_load %l1_b, %l0b, %c16_i64, %c16_i64 {transpose = true}
      : !pto.ptr<f16, mat>, !pto.ptr<f16, right>, i64, i64
    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.mad %l0a, %l0b, %l0c, %c16_i64, %c16_i64, %c16_i64
      : !pto.ptr<f16, left>, !pto.ptr<f16, right>, !pto.ptr<f32, acc>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.acc_store_gm %l0c, %c_gm, %c16_i64, %c16_i64, %c16_i64, %c48_i64,
      %c0_i64, %c0_i64, %c0_i64, %c0_i64, %c0_i64, nz2dn(%c1_i64)
      : !pto.ptr<f32, acc>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64, i64, i64, i64, nz2dn(i64)
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
