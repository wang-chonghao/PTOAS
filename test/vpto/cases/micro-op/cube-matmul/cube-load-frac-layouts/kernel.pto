    pto.cube_load_frac %id_gm, %mat_src, nd2nz,
        shape(%c40_i64, %c50_i64),
        src_layout(%c100_i64),
        dst_group(%c1_i64, %c1_i64, %c48_i64, %c0_i64),
        ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, mat>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.cube_load_frac %src_gm, %mat_id, nd2nz,
