    pto.mte_ub_gm %ub_out_m7, %arg15, %c128_i64_m7
      nburst(%c32_i64_m7, %c128_i64_m7, %c128_i64_m7)
      : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>

    return
  }
}
