      %f4e2_bf16_p2 = pto.vcvt %f4e2_p2, %mask_b8 {part = "P2"} : !pto.vreg<256x!pto.f4E2M1x2>, !pto.mask<b8> -> !pto.vreg<128xbf16>
      %f4e2_out_p2 = pto.vcvt %f4e2_bf16_p2, %mask_b16 {rnd = "R", part = "P2"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256x!pto.f4E2M1x2>
      pto.vsts %f4e2_out_p2, %ub_f4e2_out[%c512], %mask_b8 : !pto.vreg<256x!pto.f4E2M1x2>, !pto.ptr<!pto.f4E2M1x2, ub>, !pto.mask<b8>
      %f4e2_p3 = pto.vlds %ub_f4e2_in[%c768] : !pto.ptr<!pto.f4E2M1x2, ub> -> !pto.vreg<256x!pto.f4E2M1x2>
      %f4e2_bf16_p3 = pto.vcvt %f4e2_p3, %mask_b8 {part = "P3"} : !pto.vreg<256x!pto.f4E2M1x2>, !pto.mask<b8> -> !pto.vreg<128xbf16>
      %f4e2_out_p3 = pto.vcvt %f4e2_bf16_p3, %mask_b16 {rnd = "R", part = "P3"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256x!pto.f4E2M1x2>
      pto.vsts %f4e2_out_p3, %ub_f4e2_out[%c768], %mask_b8 : !pto.vreg<256x!pto.f4E2M1x2>, !pto.ptr<!pto.f4E2M1x2, ub>, !pto.mask<b8>
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_f8e4_out_u8, %f8e4_out, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_f8e5_out_u8, %f8e5_out, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_hif8_out_u8, %hif8_out, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_f4e1_out_u8, %f4e1_out, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_f4e2_out_u8, %f4e2_out, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
