      %hif8_out_p2 = pto.vcvt %hif8_f32_p2, %mask_b32 {rnd = "A", sat = "NOSAT", part = "P2"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
