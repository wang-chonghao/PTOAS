      %f8e5_f32_p2 = pto.vcvt %f8e5_p2, %mask_b8 {part = "P2"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %f8e5_out_p2 = pto.vcvt %f8e5_f32_p2, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P2"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E5M2>
      pto.vsts %f8e5_out_p2, %ub_f8e5_out[%c512], %mask_b8 : !pto.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>, !pto.mask<b8>
