      pto.vsts %f4e1_out_p1, %ub_f4e1_out[%c256], %mask_b8 : !pto.vreg<256x!pto.f4E1M2x2>, !pto.ptr<!pto.f4E1M2x2, ub>, !pto.mask<b8>
