      %f4e1_bf16_p0 = pto.vcvt %f4e1_p0, %mask_b8 {part = "P0"} : !pto.vreg<256x!pto.f4E1M2x2>, !pto.mask<b8> -> !pto.vreg<128xbf16>
      %f4e1_out_p0 = pto.vcvt %f4e1_bf16_p0, %mask_b16 {rnd = "R", part = "P0"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256x!pto.f4E1M2x2>
