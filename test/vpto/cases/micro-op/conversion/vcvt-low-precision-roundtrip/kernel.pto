      : !pto.ptr<ui8, gm>, !pto.ptr<ui8, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %mask_b8 = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %mask_b16 = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
      %mask_b32 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>

      %f8e4_p0 = pto.vlds %ub_f8e4_in[%c0] : !pto.ptr<f8E4M3FN, ub> -> !pto.vreg<256xf8E4M3FN>
      %f8e4_f32_p0 = pto.vcvt %f8e4_p0, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E4M3FN>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %f8e4_out_p0 = pto.vcvt %f8e4_f32_p0, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P0"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E4M3FN>
      pto.vsts %f8e4_out_p0, %ub_f8e4_out[%c0], %mask_b8 : !pto.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>, !pto.mask<b8>
      %f8e4_p1 = pto.vlds %ub_f8e4_in[%c256] : !pto.ptr<f8E4M3FN, ub> -> !pto.vreg<256xf8E4M3FN>
      %f8e4_f32_p1 = pto.vcvt %f8e4_p1, %mask_b8 {part = "P1"} : !pto.vreg<256xf8E4M3FN>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %f8e4_out_p1 = pto.vcvt %f8e4_f32_p1, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P1"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E4M3FN>
      pto.vsts %f8e4_out_p1, %ub_f8e4_out[%c256], %mask_b8 : !pto.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>, !pto.mask<b8>
      %f8e4_p2 = pto.vlds %ub_f8e4_in[%c512] : !pto.ptr<f8E4M3FN, ub> -> !pto.vreg<256xf8E4M3FN>
      %f8e4_f32_p2 = pto.vcvt %f8e4_p2, %mask_b8 {part = "P2"} : !pto.vreg<256xf8E4M3FN>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %f8e4_out_p2 = pto.vcvt %f8e4_f32_p2, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P2"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E4M3FN>
      pto.vsts %f8e4_out_p2, %ub_f8e4_out[%c512], %mask_b8 : !pto.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>, !pto.mask<b8>
      %f8e4_p3 = pto.vlds %ub_f8e4_in[%c768] : !pto.ptr<f8E4M3FN, ub> -> !pto.vreg<256xf8E4M3FN>
      %f8e4_f32_p3 = pto.vcvt %f8e4_p3, %mask_b8 {part = "P3"} : !pto.vreg<256xf8E4M3FN>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %f8e4_out_p3 = pto.vcvt %f8e4_f32_p3, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P3"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E4M3FN>
      pto.vsts %f8e4_out_p3, %ub_f8e4_out[%c768], %mask_b8 : !pto.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>, !pto.mask<b8>

      %f8e5_p0 = pto.vlds %ub_f8e5_in[%c0] : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
      %f8e5_f32_p0 = pto.vcvt %f8e5_p0, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %f8e5_out_p0 = pto.vcvt %f8e5_f32_p0, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P0"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E5M2>
      pto.vsts %f8e5_out_p0, %ub_f8e5_out[%c0], %mask_b8 : !pto.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>, !pto.mask<b8>
