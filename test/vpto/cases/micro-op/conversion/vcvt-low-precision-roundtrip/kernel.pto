      %f8e5_out_p3 = pto.vcvt %f8e5_f32_p3, %mask_b32 {rnd = "R", sat = "NOSAT", part = "P3"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256xf8E5M2>
      pto.vsts %f8e5_out_p3, %ub_f8e5_out[%c768], %mask_b8 : !pto.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>, !pto.mask<b8>

      %hif8_p0 = pto.vlds %ub_hif8_in[%c0] : !pto.ptr<!pto.hif8, ub> -> !pto.vreg<256x!pto.hif8>
      %hif8_f32_p0 = pto.vcvt %hif8_p0, %mask_b8 {part = "P0"} : !pto.vreg<256x!pto.hif8>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %hif8_out_p0 = pto.vcvt %hif8_f32_p0, %mask_b32 {rnd = "A", sat = "NOSAT", part = "P0"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
