// -----------------------------------------------------------------------------
// case: micro-op/conversion/vcvt-low-precision-roundtrip
// family: conversion
// target_ops: pto.vcvt
// scenarios: fp8-f32-fp8, hif8-f32-hif8, fp4-bf16-fp4
// -----------------------------------------------------------------------------
module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vcvt_low_precision_roundtrip_kernel(%f8e4_in: !pto.ptr<ui8, gm>,
                                                 %f8e5_in: !pto.ptr<ui8, gm>,
                                                 %hif8_in: !pto.ptr<ui8, gm>,
                                                 %f4e1_in: !pto.ptr<ui8, gm>,
                                                 %f4e2_in: !pto.ptr<ui8, gm>,
                                                 %f8e4_out: !pto.ptr<ui8, gm>,
                                                 %f8e5_out: !pto.ptr<ui8, gm>,
                                                 %hif8_out: !pto.ptr<ui8, gm>,
                                                 %f4e1_out: !pto.ptr<ui8, gm>,
                                                 %f4e2_out: !pto.ptr<ui8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c256 = arith.constant 256 : index
    %c512 = arith.constant 512 : index
    %c768 = arith.constant 768 : index
    %c1024 = arith.constant 1024 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c2048_i64 = arith.constant 2048 : i64
    %c3072_i64 = arith.constant 3072 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c9216_i64 = arith.constant 9216 : i64
    %c10240_i64 = arith.constant 10240 : i64
    %c11264_i64 = arith.constant 11264 : i64
    %c12288_i64 = arith.constant 12288 : i64

    %ub_f8e4_in_u8 = pto.castptr %c0_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_f8e5_in_u8 = pto.castptr %c1024_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_hif8_in_u8 = pto.castptr %c2048_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_f4e1_in_u8 = pto.castptr %c3072_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_f4e2_in_u8 = pto.castptr %c4096_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_f8e4_out_u8 = pto.castptr %c8192_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_f8e5_out_u8 = pto.castptr %c9216_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_hif8_out_u8 = pto.castptr %c10240_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_f4e1_out_u8 = pto.castptr %c11264_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_f4e2_out_u8 = pto.castptr %c12288_i64 : i64 -> !pto.ptr<ui8, ub>

    %ub_f8e4_in = pto.castptr %c0_i64 : i64 -> !pto.ptr<f8E4M3FN, ub>
    %ub_f8e5_in = pto.castptr %c1024_i64 : i64 -> !pto.ptr<f8E5M2, ub>
    %ub_hif8_in = pto.castptr %c2048_i64 : i64 -> !pto.ptr<!pto.hif8, ub>
    %ub_f4e1_in = pto.castptr %c3072_i64 : i64 -> !pto.ptr<!pto.f4E1M2x2, ub>
    %ub_f4e2_in = pto.castptr %c4096_i64 : i64 -> !pto.ptr<!pto.f4E2M1x2, ub>
    %ub_f8e4_out = pto.castptr %c8192_i64 : i64 -> !pto.ptr<f8E4M3FN, ub>
    %ub_f8e5_out = pto.castptr %c9216_i64 : i64 -> !pto.ptr<f8E5M2, ub>
    %ub_hif8_out = pto.castptr %c10240_i64 : i64 -> !pto.ptr<!pto.hif8, ub>
    %ub_f4e1_out = pto.castptr %c11264_i64 : i64 -> !pto.ptr<!pto.f4E1M2x2, ub>
    %ub_f4e2_out = pto.castptr %c12288_i64 : i64 -> !pto.ptr<!pto.f4E2M1x2, ub>

    pto.mte_gm_ub %f8e4_in, %ub_f8e4_in_u8, %c0_i64, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<ui8, gm>, !pto.ptr<ui8, ub>, i64, i64, i64, i64, i64
    pto.mte_gm_ub %f8e5_in, %ub_f8e5_in_u8, %c0_i64, %c1024_i64
