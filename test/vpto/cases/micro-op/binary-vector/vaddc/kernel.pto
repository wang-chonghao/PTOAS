      %lhs = pto.vlds %ub_lhs[%c0] : !pto.ptr<ui32, ub> -> !pto.vreg<64xui32>
      %rhs = pto.vlds %ub_rhs[%c0] : !pto.ptr<ui32, ub> -> !pto.vreg<64xui32>
      %sum, %carry = pto.vaddc %lhs, %rhs, %mask : !pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.mask<b32> -> !pto.vreg<64xui32>, !pto.mask<b32>
      pto.vsts %sum, %ub_out[%c0], %mask : !pto.vreg<64xui32>, !pto.ptr<ui32, ub>, !pto.mask<b32>
