    %ub_carry = pto.castptr %c12288_i64 : i64 -> !pto.ptr<ui8, ub>
    %false = arith.constant false
    pto.mte_gm_ub %arg0, %ub_lhs, %c0_i64, %c256_i64
      nburst(%c1_i64, %c256_i64, %c256_i64)
      : !pto.ptr<ui32, gm>, !pto.ptr<ui32, ub>, i64, i64, i64, i64, i64
    pto.mte_gm_ub %arg1, %ub_rhs, %c0_i64, %c256_i64
