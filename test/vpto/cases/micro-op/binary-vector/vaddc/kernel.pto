module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vaddc_kernel_2d(%arg0: !pto.ptr<ui32, gm>, %arg1: !pto.ptr<ui32, gm>,
                             %arg2: !pto.ptr<ui32, gm>, %arg3: !pto.ptr<ui8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
