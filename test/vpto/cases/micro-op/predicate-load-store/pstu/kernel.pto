module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
    func.func @pstu_deep_merged_kernel(%arg0: !pto.ptr<f32, gm>, %arg1: !pto.ptr<f32, gm>, %arg2: !pto.ptr<ui32, gm>, %arg3: !pto.ptr<f32, gm>, %arg4: !pto.ptr<f32, gm>, %arg5: !pto.ptr<ui16, gm>, %arg6: !pto.ptr<f32, gm>, %arg7: !pto.ptr<f32, gm>, %arg8: !pto.ptr<ui32, gm>) attributes {pto.kernel} {
    %__deep_merge_guard = arith.constant false
    // inactive merged from pstu_init_align_outside_loop_kernel_2d
    scf.if %__deep_merge_guard {

    %c0_m0 = arith.constant 0 : index
    %c1_m0 = arith.constant 1 : index
    %c2_m0 = arith.constant 2 : index
    %c0_i64_m0 = arith.constant 0 : i64
    %c1_i64_m0 = arith.constant 1 : i64
