    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_mask_m2, %arg8, %c32_i64_m2
      nburst(%c1_i64_m2, %c32_i64_m2, %c32_i64_m2)
      : !pto.ptr<ui32, ub>, !pto.ptr<ui32, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>

