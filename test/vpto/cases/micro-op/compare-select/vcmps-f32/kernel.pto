    // inactive cross-case merge from micro-op/compare-select/vcmps-tail
    scf.if %__case_merge_guard {
      
          %c0_cmg4_2 = arith.constant 0 : index
          %c1_cmg4_2 = arith.constant 1 : index
          %c0_i64_cmg4_2 = arith.constant 0 : i64
          %c1_i64_cmg4_2 = arith.constant 1 : i64
          %c32_i64_cmg4_2 = arith.constant 32 : i64
          %c40_i32_cmg4_2 = arith.constant 40 : i32
          %c64_i64_cmg4_2 = arith.constant 64 : i64
          %c256_i64_cmg4_2 = arith.constant 256 : i64
          %threshold_cmg4_2 = arith.constant 5.000000e-01 : f32
          %false_cmg4_2 = arith.constant false
      
          %ub_src_cmg4_2 = pto.castptr %c0_i64_cmg4_2 : i64 -> !pto.ptr<f32, ub>
