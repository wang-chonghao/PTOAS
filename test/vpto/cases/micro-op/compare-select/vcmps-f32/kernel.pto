          pto.set_loop2_stride_ubtoout %c32_i64_cmg4_2, %c32_i64_cmg4_2 : i64, i64
          pto.mte_ub_gm %ub_out_cmg4_2, %arg1, %c32_i64_cmg4_2
            nburst(%c32_i64_cmg4_2, %c32_i64_cmg4_2, %c32_i64_cmg4_2)
            : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
