        %active, %next = pto.plt_b32 %remaining : i32 -> !pto.mask<b32>, i32
        %lhs = pto.vlds %ub_lhs[%c0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
        %rhs = pto.vlds %ub_rhs[%c0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
        %pred = pto.vcmp %lhs, %rhs, %active, "eq" : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.mask<b32>
