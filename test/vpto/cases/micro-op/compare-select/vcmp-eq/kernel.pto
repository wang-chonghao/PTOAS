module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vcmp_eq_kernel_2d(%arg0: !pto.ptr<f32, gm>, %arg1: !pto.ptr<f32, gm>,
                               %arg2: !pto.ptr<ui8, gm>) attributes {pto.kernel} {
