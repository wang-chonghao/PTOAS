    pto.set_loop1_stride_outtoub %c256_i64, %c256_i64 : i64, i64
    pto.set_loop2_stride_outtoub %c256_i64, %c256_i64 : i64, i64
    pto.mte_gm_ub %arg0, %ub_lhs, %c0_i64, %c256_i64
      nburst(%c64_i64, %c256_i64, %c256_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64
    pto.mte_gm_ub %arg1, %ub_rhs, %c0_i64, %c256_i64
      nburst(%c64_i64, %c256_i64, %c256_i64)
