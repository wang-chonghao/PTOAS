  func.func @TSORT32_f32_16x32(%src_ptr: !pto.ptr<f32>, %idx_ptr: !pto.ptr<ui32>, %dst_ptr: !pto.ptr<f32>) attributes {pto.kernel} {
    %c0    = arith.constant 0    : index
    %c1    = arith.constant 1    : index
