    %src_view = pto.make_tensor_view %src_ptr,
      shape = [%c1, %c1, %c1, %c2, %c32],
      strides = [%c64, %c64, %c64, %c32, %c1]
      : !pto.tensor_view<1x1x1x2x32xf32>
