      sizes = [%c1, %c1, %c1, %c128, %c127]
      : !pto.tensor_view<1x1x1x128x127xf32> -> !pto.partition_tensor_view<1x1x1x128x127xf32>
    %dst_out_part = pto.partition_view %dst_out_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c128, %c160]
      : !pto.tensor_view<1x1x1x128x160xf32> -> !pto.partition_tensor_view<1x1x1x128x160xf32>

    // Src tile: LoadPadVal=Max (pad=2), src physical=128x160, v_col=127
    %src = pto.alloc_tile
      : !pto.tile_buf<vec, 128x160xf32, valid=128x127, pad=2>
    // Dst tile: FillPadVal=Max (pad=2), dst physical=128x160, v_col=160 (full output)
    %dst = pto.alloc_tile
      : !pto.tile_buf<vec, 128x160xf32, pad=2>

    pto.tload ins(%src_part : !pto.partition_tensor_view<1x1x1x128x127xf32>)
              outs(%src : !pto.tile_buf<vec, 128x160xf32, valid=128x127, pad=2>)

    pto.tfillpad ins(%src : !pto.tile_buf<vec, 128x160xf32, valid=128x127, pad=2>)
                 outs(%dst : !pto.tile_buf<vec, 128x160xf32, pad=2>)

    pto.tstore ins(%dst : !pto.tile_buf<vec, 128x160xf32, pad=2>)
               outs(%dst_out_part : !pto.partition_tensor_view<1x1x1x128x160xf32>)
    return
  }

