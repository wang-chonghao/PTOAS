    %dst_view = pto.make_tensor_view %dst_ptr,
      shape = [%c1, %c1, %c1, %c15, %c192],
      strides = [%c2880, %c2880, %c2880, %c192, %c1]
      : !pto.tensor_view<1x1x1x15x192xi16>

