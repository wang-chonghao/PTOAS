  // Case: i32 64x64, valid 60x60, scalar=99
  func.func @TEXPANDS_i32_64x64_valid_60x60(%dst_ptr: !pto.ptr<i32>) attributes {pto.kernel} {
    %c0    = arith.constant 0    : index
    %c1    = arith.constant 1    : index
    %c60   = arith.constant 60   : index
    %c64   = arith.constant 64   : index
    %c3600 = arith.constant 3600 : index
