      strides = [%c1024, %c1024, %c1024, %c64, %c1]
      : !pto.tensor_view<1x1x1x16x64xf32>

    %dst_part = pto.partition_view %dst_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c12, %c48]
      : !pto.tensor_view<1x1x1x16x64xf32> -> !pto.partition_tensor_view<1x1x1x12x48xf32>

    %dst = pto.alloc_tile
      : !pto.tile_buf<vec, 16x64xf32, valid=12x48>

    pto.texpands ins(%scalar : f32)
                 outs(%dst : !pto.tile_buf<vec, 16x64xf32, valid=12x48>)

    pto.tstore ins(%dst : !pto.tile_buf<vec, 16x64xf32, valid=12x48>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x12x48xf32>)
    return
  }

  // Case: f32 64x64, valid 60x60, scalar=42.0
  func.func @TEXPANDS_f32_64x64_valid_60x60(%dst_ptr: !pto.ptr<f32>) attributes {pto.kernel} {
    %c0    = arith.constant 0    : index
    %c1    = arith.constant 1    : index
    %c60   = arith.constant 60   : index
    %c64   = arith.constant 64   : index
    %c3600 = arith.constant 3600 : index
    %c4096 = arith.constant 4096 : index
