      : !pto.tensor_view<1x1x1x64x64xi32>

    %dst_part = pto.partition_view %dst_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c64, %c64]
      : !pto.tensor_view<1x1x1x64x64xi32> -> !pto.partition_tensor_view<1x1x1x64x64xi32>

    %dst = pto.alloc_tile
      : !pto.tile_buf<vec, 64x64xi32>

    pto.texpands ins(%scalar : i32)
                 outs(%dst : !pto.tile_buf<vec, 64x64xi32>)

    pto.tstore ins(%dst : !pto.tile_buf<vec, 64x64xi32>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x64x64xi32>)
