      : !pto.tensor_view<1x1x1x64x64xf32> -> !pto.partition_tensor_view<1x1x1x60x60xf32>

    %dst = pto.alloc_tile
      : !pto.tile_buf<vec, 64x64xf32, valid=60x60>

    pto.texpands ins(%scalar : f32)
