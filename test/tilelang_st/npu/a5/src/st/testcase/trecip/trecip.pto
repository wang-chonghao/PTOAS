  // Case 4: f32 66x72, valid 64x64 (pad case)
  func.func @TRECIP_f32_64x64_pad(%a_ptr: !pto.ptr<f32>, %b_ptr: !pto.ptr<f32>) attributes {pto.kernel} {
    %c0    = arith.constant 0    : index
    %c1    = arith.constant 1    : index
