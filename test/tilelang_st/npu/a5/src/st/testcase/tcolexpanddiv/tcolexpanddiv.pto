    pto.tcolexpanddiv ins(%src0, %src1 : !pto.tile_buf<vec, 8x32xf32>,
                                          !pto.tile_buf<vec, 1x32xf32>)
                       outs(%dst : !pto.tile_buf<vec, 8x32xf32>)

    pto.tstore ins(%dst : !pto.tile_buf<vec, 8x32xf32>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x8x32xf32>)
    return
  }

