              outs(%src0 : !pto.tile_buf<vec, 2x512xf32>)
    pto.tload ins(%src1_part : !pto.partition_tensor_view<1x1x1x2x512xf32>)
              outs(%src1 : !pto.tile_buf<vec, 2x512xf32>)

    pto.tsel ins(%mask, %src0, %src1, %tmp : !pto.tile_buf<vec, 2x64xi8>,
