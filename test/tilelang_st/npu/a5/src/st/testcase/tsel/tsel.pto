  // Case: f16 2x128
  func.func @TSEL_f16_2x128(%mask_ptr: !pto.ptr<i8>, %src0_ptr: !pto.ptr<f16>, %src1_ptr: !pto.ptr<f16>, %dst_ptr: !pto.ptr<f16>) attributes {pto.kernel} {
