    pto.tmov ins(%src : !pto.tile_buf<vec, 128x128xui8>)
             outs(%dst : !pto.tile_buf<vec, 128x128xui8>)

    pto.tstore ins(%dst : !pto.tile_buf<vec, 128x128xui8>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x128x128xui8>)
    return
  }
}