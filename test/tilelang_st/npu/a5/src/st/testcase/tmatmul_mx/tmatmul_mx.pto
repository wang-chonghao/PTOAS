     -> !pto.ptr<f32, l0c>

    pto.mte_gm_l1 %a_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<!pto.f4E2M1x2, gm>, !pto.ptr<!pto.f4E2M1x2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c64_i64, %c64_i64)
      : !pto.ptr<!pto.f4E2M1x2, gm>, !pto.ptr<!pto.f4E2M1x2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c2_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<!pto.f4E1M2x2, gm>, !pto.ptr<!pto.f4E1M2x2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c2_i64, %c64_i64, %c64_i64)
      : !pto.ptr<!pto.f4E1M2x2, gm>, !pto.ptr<!pto.f4E1M2x2, l1>, i64, i64, i64, i64, loop i64, i64, i64

