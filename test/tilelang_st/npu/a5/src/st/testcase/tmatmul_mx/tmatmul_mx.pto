     -> !pto.ptr<!pto.f4E2M1x2, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=!pto.f4E1M2x2, rows=128, cols=64, v_row=128, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<!pto.f4E1M2x2, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>

    pto.mte_gm_l1_frac %a_gm, %l1_a_data, nd2nz,
      shape(%c128_i64, %c64_i64), src_layout(%c64_i64),
      dst_group(%c1_i64, %c1_i64, %c128_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<!pto.f4E2M1x2, gm>, !pto.ptr<!pto.f4E2M1x2, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c8_i64, %c64_i64, %c64_i64)
      : !pto.ptr<!pto.f4E2M1x2, gm>, !pto.ptr<!pto.f4E2M1x2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1_frac %b_gm, %l1_b_data, nd2nz,
      shape(%c128_i64, %c32_i64), src_layout(%c32_i64),
      dst_group(%c1_i64, %c1_i64, %c128_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<!pto.f4E1M2x2, gm>, !pto.ptr<!pto.f4E1M2x2, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c64_i64, %c64_i64)
      : !pto.ptr<!pto.f4E1M2x2, gm>, !pto.ptr<!pto.f4E1M2x2, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c128_i64, %c128_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.f4E2M1x2, l1>, !pto.ptr<!pto.f4E2M1x2, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c128_i64, %c64_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<!pto.f4E1M2x2, l1>, !pto.ptr<!pto.f4E1M2x2, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c128_i64, %c128_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.f4E2M1x2, l1>, !pto.ptr<!pto.f4E2M1x2, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c128_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.f4E1M2x2, l1>, !pto.ptr<!pto.f4E1M2x2, l0b>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile :
                       !pto.tile_buf<loc=left, dtype=!pto.f4E2M1x2, rows=128, cols=128, v_row=128, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=4, v_row=128, v_col=4, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                       !pto.tile_buf<loc=right, dtype=!pto.f4E1M2x2, rows=128, cols=64, v_row=128, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=4, cols=64, v_row=4, v_col=64, blayout=col_major, slayout=col_major, fractal=32, pad=0>)
                   outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_gm, %c128_i64, %c64_i64, %c128_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
