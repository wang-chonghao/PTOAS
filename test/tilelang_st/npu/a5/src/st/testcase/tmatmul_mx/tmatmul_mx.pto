    %b_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=2, cols=64, v_row=2, v_col=54, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=64, v_row=10, v_col=54, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=16, cols=64, v_row=10, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=64, cols=64, v_row=64, v_col=54, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<f8E5M2, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=64, v_row=10, v_col=54, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>

    pto.mte_gm_l1 %a_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c32_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c2_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c10_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
