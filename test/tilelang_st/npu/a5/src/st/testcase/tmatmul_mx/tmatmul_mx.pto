    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=115, v_col=30, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=!pto.f4E2M1x2, rows=128, cols=64, v_row=115, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<!pto.f4E2M1x2, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=!pto.f4E1M2x2, rows=64, cols=64, v_row=64, v_col=30, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<!pto.f4E1M2x2, l0b>
