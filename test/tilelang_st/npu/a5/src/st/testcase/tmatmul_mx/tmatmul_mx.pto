module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  // =========================================================================
  // fp8_e5m2_128x64x64  (M=128, K=64, N=64)
  // =========================================================================
  func.func @TMATMUL_MX_fp8_e5m2_128x64x64(
      %a_gm: !pto.ptr<f8E5M2, gm>,
      %b_gm: !pto.ptr<f8E5M2, gm>,
      %a_scale_gm: !pto.ptr<f8E5M2, gm>,
      %b_scale_gm: !pto.ptr<f8E5M2, gm>,
      %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64  = arith.constant 0    : i64
    %c1_i64  = arith.constant 1    : i64
    %c64_i64 = arith.constant 64   : i64
    %c128_i64 = arith.constant 128 : i64
    %c256_i64 = arith.constant 256 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c8448_i64 = arith.constant 8448 : i64
    %c12544_i64 = arith.constant 12544 : i64

    %l1_a_data  = pto.castptr %c0_i64    : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_a_scale = pto.castptr %c8192_i64  : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_b_data  = pto.castptr %c8448_i64  : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_b_scale = pto.castptr %c12544_i64 : i64 -> !pto.ptr<f8E5M2, l1>
    %lhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=left, dtype=f8E5M2, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=2, v_row=128, v_col=2, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %rhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=64, cols=64, v_row=64, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %b_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=2, cols=64, v_row=2, v_col=64, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=f8E5M2, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E5M2, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=64, cols=64, v_row=64, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<f8E5M2, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>

    pto.mte_gm_l1 %a_gm, %l1_a_data, %c8192_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c256_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c4096_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c128_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c128_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c64_i64, %c64_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c128_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c64_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0b>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile :
                       !pto.tile_buf<loc=left, dtype=f8E5M2, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=2, v_row=128, v_col=2, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                       !pto.tile_buf<loc=right, dtype=f8E5M2, rows=64, cols=64, v_row=64, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=2, cols=64, v_row=2, v_col=64, blayout=col_major, slayout=col_major, fractal=32, pad=0>)
                   outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=128, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_gm, %c128_i64, %c64_i64, %c128_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
  // =========================================================================
  // fp8_e4m3_127x72x64  (M=127, K=72->128, N=64)
  // =========================================================================
  func.func @TMATMUL_MX_fp8_e4m3_127x72x64(
      %a_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_gm: !pto.ptr<f8E4M3FN, gm>,
      %a_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64  = arith.constant 0    : i64
    %c1_i64  = arith.constant 1    : i64
    %c64_i64 = arith.constant 64   : i64
    %c127_i64 = arith.constant 127 : i64
    %c128_i64 = arith.constant 128 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c16896_i64 = arith.constant 16896 : i64
    %c25088_i64 = arith.constant 25088 : i64
    %c16_i64 = arith.constant 16 : i64
    %c8_i64 = arith.constant 8 : i64
    %c4_i64 = arith.constant 4 : i64
    %false = arith.constant false

    %l1_a_data  = pto.castptr %c0_i64     : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_a_scale = pto.castptr %c16384_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_data  = pto.castptr %c16896_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_scale = pto.castptr %c25088_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %lhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=128, v_row=127, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=4, v_row=127, v_col=4, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %rhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=128, cols=64, v_row=128, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %b_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=4, cols=64, v_row=4, v_col=64, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=127, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=128, v_row=127, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=128, cols=64, v_row=128, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=127, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>

    // Use mte_gm_l1 for both A and B (same as FP4)
    pto.mte_gm_l1 %a_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c16_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c8_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c8_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c127_i64, %c128_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c128_i64, %c64_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c127_i64, %c128_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c128_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile :
                       !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=128, v_row=127, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=4, v_row=127, v_col=4, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                       !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=128, cols=64, v_row=128, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=4, cols=64, v_row=4, v_col=64, blayout=col_major, slayout=col_major, fractal=32, pad=0>)
                   outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=127, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_gm, %c128_i64, %c64_i64, %c128_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
  // =========================================================================
  // fp8_e4m3_e5m2_128x110x63  (M=128, K=110->128, N=63)
  // =========================================================================
  func.func @TMATMUL_MX_fp8_e4m3_e5m2_128x110x63(
      %a_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_gm: !pto.ptr<f8E5M2, gm>,
      %a_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_scale_gm: !pto.ptr<f8E5M2, gm>,
      %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64  = arith.constant 0    : i64
    %c1_i64  = arith.constant 1    : i64
    %c63_i64 = arith.constant 63   : i64
    %c64_i64 = arith.constant 64   : i64
    %c128_i64 = arith.constant 128 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c16896_i64 = arith.constant 16896 : i64
    %c25088_i64 = arith.constant 25088 : i64
    %c16_i64 = arith.constant 16 : i64
    %c8_i64 = arith.constant 8 : i64
    %c4_i64 = arith.constant 4 : i64

    %l1_a_data  = pto.castptr %c0_i64     : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_a_scale = pto.castptr %c16384_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_data  = pto.castptr %c16896_i64  : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_b_scale = pto.castptr %c25088_i64  : i64 -> !pto.ptr<f8E5M2, l1>
    %lhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=128, v_row=128, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=4, v_row=128, v_col=4, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %rhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=128, cols=64, v_row=128, v_col=63, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %b_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=4, cols=64, v_row=4, v_col=63, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=128, v_col=63, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=128, v_row=128, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=128, cols=64, v_row=128, v_col=63, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<f8E5M2, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=64, v_row=128, v_col=63, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>

    pto.mte_gm_l1 %a_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c16_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c8_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c8_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c128_i64, %c128_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c128_i64, %c63_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c128_i64, %c128_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
