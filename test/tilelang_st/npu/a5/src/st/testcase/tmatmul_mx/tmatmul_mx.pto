      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0b>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile :
                       !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=16, cols=64, v_row=10, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=16, cols=2, v_row=10, v_col=2, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                       !pto.tile_buf<loc=right, dtype=f8E5M2, rows=64, cols=64, v_row=64, v_col=54, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                       !pto.tile_buf<loc=scaling, dtype=f16, rows=2, cols=64, v_row=2, v_col=54, blayout=col_major, slayout=col_major, fractal=32, pad=0>)
                   outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=64, v_row=10, v_col=54, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_gm, %c16_i64, %c64_i64, %c16_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

