    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c64_i64, %c30_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.f4E1M2x2, l1>, !pto.ptr<!pto.f4E1M2x2, l0b>, i64, i64, i64, i64

