    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c47_i64, %c128_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.f4E1M2x2, l1>, !pto.ptr<!pto.f4E1M2x2, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c128_i64, %c62_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.f4E1M2x2, l1>, !pto.ptr<!pto.f4E1M2x2, l0b>, i64, i64, i64, i64
    pto.mte_l1_bt %l1_bias, %bt, %c62_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f32, l1>, !pto.ptr<f32, bt>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx.bias ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile, %bias_tile : !pto.tile_buf<loc=left, dtype=!pto.f4E1M2x2, rows=48, cols=128, v_row=47, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=48, cols=4, v_row=47, v_col=4, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=right, dtype=!pto.f4E1M2x2, rows=128, cols=64, v_row=128, v_col=62, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=4, cols=64, v_row=4, v_col=62, blayout=col_major, slayout=col_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=64, v_row=1, v_col=62, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                       outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=48, cols=64, v_row=47, v_col=62, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_gm, %c47_i64, %c62_i64, %c48_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

  // =========================================================================
  // bias_fp8_e4m3_e5m2_64x192x64  (M=64, K=192, N=64)
  // =========================================================================
  func.func @TMATMUL_MX_bias_fp8_e4m3_e5m2_64x192x64(
      %a_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_gm: !pto.ptr<f8E5M2, gm>,
      %a_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_scale_gm: !pto.ptr<f8E5M2, gm>,
      %bias_gm: !pto.ptr<f32, gm>,
      %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64  = arith.constant 0    : i64
    %c1_i64  = arith.constant 1    : i64
    %c64_i64 = arith.constant 64   : i64
    %c192_i64 = arith.constant 192 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c12288_i64 = arith.constant 12288 : i64
    %c12672_i64 = arith.constant 12672 : i64
    %c24960_i64 = arith.constant 24960 : i64
    %c25344_i64 = arith.constant 25344 : i64
    %c12_i64 = arith.constant 12 : i64
    %c6_i64 = arith.constant 6 : i64
    %c4_i64 = arith.constant 4 : i64

    %l1_a_data  = pto.castptr %c0_i64     : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_a_scale = pto.castptr %c12288_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_data  = pto.castptr %c12672_i64  : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_b_scale = pto.castptr %c24960_i64  : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_bias    = pto.castptr %c25344_i64  : i64 -> !pto.ptr<f32, l1>
    %lhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=64, cols=192, v_row=64, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=64, cols=6, v_row=64, v_col=6, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %rhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=192, cols=64, v_row=192, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %b_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=6, cols=64, v_row=6, v_col=64, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %bias_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=64, v_row=1, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=64, cols=64, v_row=64, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=64, cols=192, v_row=64, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=f8E5M2, rows=192, cols=64, v_row=192, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<f8E5M2, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=64, cols=64, v_row=64, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>
    %bt = pto.tile_buf_addr %bias_tile
      : !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=64, v_row=1, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>
     -> !pto.ptr<f32, bt>

    pto.mte_gm_l1 %a_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c12_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c6_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c12_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c6_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %bias_gm, %l1_bias, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c64_i64, %c192_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c192_i64, %c64_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c64_i64, %c192_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c192_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0b>, i64, i64, i64, i64
    pto.mte_l1_bt %l1_bias, %bt, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f32, l1>, !pto.ptr<f32, bt>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx.bias ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile, %bias_tile : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=64, cols=192, v_row=64, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=64, cols=6, v_row=64, v_col=6, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=right, dtype=f8E5M2, rows=192, cols=64, v_row=192, v_col=64, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=6, cols=64, v_row=6, v_col=64, blayout=col_major, slayout=col_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=64, v_row=1, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                       outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=64, cols=64, v_row=64, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_gm, %c64_i64, %c64_i64, %c64_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

}
