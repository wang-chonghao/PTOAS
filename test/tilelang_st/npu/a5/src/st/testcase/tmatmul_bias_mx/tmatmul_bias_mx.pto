module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {

  // =========================================================================
  // bias_fp8_e5m2_e4m3_115x64x30  (M=115, K=64, N=30)
  // =========================================================================
  func.func @TMATMUL_MX_bias_fp8_e5m2_e4m3_115x64x30(
      %a_gm: !pto.ptr<f8E5M2, gm>,
      %b_gm: !pto.ptr<f8E4M3FN, gm>,
      %a_scale_gm: !pto.ptr<f8E5M2, gm>,
      %b_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %bias_gm: !pto.ptr<f32, gm>,
      %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64  = arith.constant 0    : i64
    %c1_i64  = arith.constant 1    : i64
    %c30_i64 = arith.constant 30   : i64
    %c32_i64 = arith.constant 32   : i64
    %c64_i64 = arith.constant 64   : i64
    %c115_i64 = arith.constant 115 : i64
    %c128_i64 = arith.constant 128 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c8448_i64 = arith.constant 8448 : i64
    %c10496_i64 = arith.constant 10496 : i64
    %c10624_i64 = arith.constant 10624 : i64
    %c8_i64 = arith.constant 8 : i64
    %c4_i64 = arith.constant 4 : i64
    %c2_i64 = arith.constant 2 : i64

    %l1_a_data  = pto.castptr %c0_i64    : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_a_scale = pto.castptr %c8192_i64  : i64 -> !pto.ptr<f8E5M2, l1>
    %l1_b_data  = pto.castptr %c8448_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_scale = pto.castptr %c10496_i64 : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_bias    = pto.castptr %c10624_i64 : i64 -> !pto.ptr<f32, l1>
    %lhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=left, dtype=f8E5M2, rows=128, cols=64, v_row=115, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=2, v_row=115, v_col=2, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %rhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=64, cols=32, v_row=64, v_col=30, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %b_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=2, cols=32, v_row=2, v_col=30, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %bias_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=32, v_row=1, v_col=30, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=32, v_row=115, v_col=30, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=f8E5M2, rows=128, cols=64, v_row=115, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E5M2, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=64, cols=32, v_row=64, v_col=30, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=32, v_row=115, v_col=30, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>
    %bt = pto.tile_buf_addr %bias_tile
      : !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=32, v_row=1, v_col=30, blayout=row_major, slayout=none_box, fractal=512, pad=0>
     -> !pto.ptr<f32, bt>

    pto.mte_gm_l1 %a_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c8_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %a_scale_gm, %l1_a_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c4_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c2_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64
    pto.mte_gm_l1 %bias_gm, %l1_bias, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c2_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c115_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c64_i64, %c30_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c115_i64, %c64_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E5M2, l1>, !pto.ptr<f8E5M2, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c64_i64, %c30_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    pto.mte_l1_bt %l1_bias, %bt, %c30_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f32, l1>, !pto.ptr<f32, bt>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx.bias ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile, %bias_tile : !pto.tile_buf<loc=left, dtype=f8E5M2, rows=128, cols=64, v_row=115, v_col=64, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=2, v_row=115, v_col=2, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=64, cols=32, v_row=64, v_col=30, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=2, cols=32, v_row=2, v_col=30, blayout=col_major, slayout=col_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=32, v_row=1, v_col=30, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                       outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=32, v_row=115, v_col=30, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c_gm, %c115_i64, %c30_i64, %c128_i64, %c32_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

  // =========================================================================
  // bias_fp8_e4m3_200x192x95  (M=200, K=192, N=95)
  // Split logical M into 128 + 72; chunk1 uses an 80-row physical extent.
  // =========================================================================
  func.func @TMATMUL_MX_bias_fp8_e4m3_200x192x95(
      %a0_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_gm: !pto.ptr<f8E4M3FN, gm>,
      %a0_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %b_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %bias_gm: !pto.ptr<f32, gm>,
      %c0_gm: !pto.ptr<f32, gm>,
      %a1_gm: !pto.ptr<f8E4M3FN, gm>,
      %a1_scale_gm: !pto.ptr<f8E4M3FN, gm>,
      %c1_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64  = arith.constant 0    : i64
    %c1_i64  = arith.constant 1    : i64
    %c64_i64 = arith.constant 64   : i64
    %c72_i64 = arith.constant 72   : i64
    %c80_i64 = arith.constant 80   : i64
    %c95_i64 = arith.constant 95   : i64
    %c128_i64 = arith.constant 128 : i64
    %c192_i64 = arith.constant 192 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c38912_i64 = arith.constant 38912 : i64
    %c40192_i64 = arith.constant 40192 : i64
    %c58624_i64 = arith.constant 58624 : i64
    %c59392_i64 = arith.constant 59392 : i64
    %c32_i64 = arith.constant 32 : i64
    %c39_i64 = arith.constant 39 : i64
    %c38_i64 = arith.constant 38 : i64
    %c20_i64 = arith.constant 20 : i64
    %c24_i64 = arith.constant 24 : i64
    %c15_i64 = arith.constant 15 : i64
    %c18_i64 = arith.constant 18 : i64
    %c12_i64 = arith.constant 12 : i64
    %c6_i64 = arith.constant 6 : i64

    %l1_a_data  = pto.castptr %c0_i64     : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_a_scale = pto.castptr %c38912_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_data  = pto.castptr %c40192_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_b_scale = pto.castptr %c58624_i64  : i64 -> !pto.ptr<f8E4M3FN, l1>
    %l1_bias    = pto.castptr %c59392_i64  : i64 -> !pto.ptr<f32, l1>
    %lhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=192, v_row=128, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=6, v_row=128, v_col=6, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %rhs_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=192, cols=128, v_row=192, v_col=95, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %b_scale_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=6, cols=128, v_row=6, v_col=95, blayout=col_major, slayout=col_major, fractal=32, pad=0>
    %bias_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=128, v_row=1, v_col=95, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=128, v_row=128, v_col=95, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %lhs_tail_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=80, cols=192, v_row=72, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_scale_tail_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=scaling, dtype=f16, rows=80, cols=6, v_row=72, v_col=6, blayout=row_major, slayout=row_major, fractal=32, pad=0>
    %dst_tail_tile = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<loc=acc, dtype=f32, rows=80, cols=128, v_row=72, v_col=95, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %l0a = pto.tile_buf_addr %lhs_tile
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=192, v_row=128, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0a>
    %l0b = pto.tile_buf_addr %rhs_tile
      : !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=192, cols=128, v_row=192, v_col=95, blayout=row_major, slayout=col_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0b>
    %l0c = pto.tile_buf_addr %dst_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=128, v_row=128, v_col=95, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>
    %bt = pto.tile_buf_addr %bias_tile
      : !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=128, v_row=1, v_col=95, blayout=row_major, slayout=none_box, fractal=512, pad=0>
     -> !pto.ptr<f32, bt>
    %l0a_tail = pto.tile_buf_addr %lhs_tail_tile
      : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=80, cols=192, v_row=72, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f8E4M3FN, l0a>
    %l0c_tail = pto.tile_buf_addr %dst_tail_tile
      : !pto.tile_buf<loc=acc, dtype=f32, rows=80, cols=128, v_row=72, v_col=95, blayout=col_major, slayout=row_major, fractal=512, pad=0>
     -> !pto.ptr<f32, l0c>

    // ---- Chunk 0: rows [0, 128) ----
    pto.mte_gm_l1 %a0_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c24_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %a0_scale_gm, %l1_a_scale, %c32_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c24_i64, %c32_i64, %c32_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_gm, %l1_b_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c18_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %b_scale_gm, %l1_b_scale, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c12_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %bias_gm, %l1_bias, %c64_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c6_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a, %c128_i64, %c192_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c192_i64, %c95_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a, %c128_i64, %c192_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c192_i64, %c95_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    %c96_i64 = arith.constant 96 : i64
    pto.mte_l1_bt %l1_bias, %bt, %c96_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f32, l1>, !pto.ptr<f32, bt>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

    pto.tmatmul.mx.bias ins(%lhs_tile, %a_scale_tile, %rhs_tile, %b_scale_tile, %bias_tile : !pto.tile_buf<loc=left, dtype=f8E4M3FN, rows=128, cols=192, v_row=128, v_col=192, blayout=col_major, slayout=row_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=128, cols=6, v_row=128, v_col=6, blayout=row_major, slayout=row_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=right, dtype=f8E4M3FN, rows=192, cols=128, v_row=192, v_col=95, blayout=row_major, slayout=col_major, fractal=512, pad=0>,
                            !pto.tile_buf<loc=scaling, dtype=f16, rows=6, cols=128, v_row=6, v_col=95, blayout=col_major, slayout=col_major, fractal=32, pad=0>,
                            !pto.tile_buf<loc=bias, dtype=f32, rows=1, cols=128, v_row=1, v_col=95, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                       outs(%dst_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=128, cols=128, v_row=128, v_col=95, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]

    pto.mte_l0c_gm %l0c, %c0_gm, %c128_i64, %c95_i64, %c128_i64, %c128_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    // ---- Chunk 1: rows [128, 200) ----
    pto.mte_gm_l1 %a1_gm, %l1_a_data, %c1024_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c15_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64
    pto.mte_gm_l1 %a1_scale_gm, %l1_a_scale, %c32_i64 nburst(%c1_i64, %c0_i64, %c0_i64) loop(%c15_i64, %c32_i64, %c32_i64)
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, l1>, i64, i64, i64, i64, loop i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]

    pto.mte_l1_l0a %l1_a_data, %l0a_tail, %c72_i64, %c192_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b %l1_b_data, %l0b, %c192_i64, %c95_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    pto.mte_l1_l0a_mx %l1_a_scale, %l0a_tail, %c72_i64, %c192_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0a>, i64, i64, i64, i64
    pto.mte_l1_l0b_mx %l1_b_scale, %l0b, %c192_i64, %c95_i64, %c0_i64, %c0_i64
      : !pto.ptr<f8E4M3FN, l1>, !pto.ptr<f8E4M3FN, l0b>, i64, i64, i64, i64
    %c96_chunk1_i64 = arith.constant 96 : i64
    pto.mte_l1_bt %l1_bias, %bt, %c96_chunk1_i64 nburst(%c1_i64, %c0_i64, %c0_i64)
      : !pto.ptr<f32, l1>, !pto.ptr<f32, bt>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]

