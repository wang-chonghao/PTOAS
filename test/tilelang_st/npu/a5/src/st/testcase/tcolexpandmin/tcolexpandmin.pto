  func.func @TCOLEXPANDMIN_fp16_10_64_1_64(%src0_ptr: !pto.ptr<f16>, %src1_ptr: !pto.ptr<f16>, %dst_ptr: !pto.ptr<f16>) attributes {pto.kernel} {
    %c0    = arith.constant 0    : index
    %c1    = arith.constant 1    : index
    %c10   = arith.constant 10   : index
    %c64   = arith.constant 64   : index
    %c640  = arith.constant 640  : index

    %src0_view = pto.make_tensor_view %src0_ptr,
      shape = [%c1, %c1, %c1, %c10, %c64],
      strides = [%c640, %c640, %c640, %c64, %c1]
      : !pto.tensor_view<1x1x1x10x64xf16>
    
    %src1_view = pto.make_tensor_view %src1_ptr,
